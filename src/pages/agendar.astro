<style is:global>
  @keyframes spin    { to { transform: rotate(360deg); } }
  @keyframes shimmer { to { background-position: -200% 0; } }

  /* ── Skeleton loaders ── */
  .skel-card {
    background:#fff;padding:28px 24px;
  }
  .skel {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: 2px;
  }
  .skel-circle {
    width:52px;height:52px;border-radius:50%;flex-shrink:0;
  }
  .skel-line { display:block; }

  /* ── Tarjeta barbero ── */
  .barber-card {
    background:#fff;padding:22px 20px;cursor:pointer;transition:all .2s;
    position:relative;display:flex;align-items:center;gap:16px;
  }
  .barber-card:hover:not(.selected) { background:#faf7f3; }
  .barber-card.selected { background:var(--black);box-shadow:inset 4px 0 0 var(--gold); }
  .barber-card.any-barber { border:2px dashed #ddd; }
  .barber-card.any-barber.selected { border-color:var(--gold); }
  .barber-card .b-name { font-family:'Prata',serif;font-size:1rem;color:var(--text-dark);transition:color .2s; }
  .barber-card.selected .b-name { color:#fff; }
  .barber-card .b-specs { font-family:'Work Sans',sans-serif;font-size:11px;color:#999;margin-top:4px;transition:color .2s; }
  .barber-card.selected .b-specs { color:#888; }
  .barber-card .b-check {
    display:none;position:absolute;top:12px;right:12px;
    width:22px;height:22px;border-radius:50%;background:var(--gold);
    align-items:center;justify-content:center;flex-shrink:0;
  }
  .barber-card.selected .b-check { display:flex; }

  /* ── Responsive wizard ─────────────────────── */
  @media (max-width:640px) { .form-row { grid-template-columns:1fr !important; } }

  /* Indicador de pasos más pequeño en móvil */
  @media (max-width:480px) {
    .step-circle { width:36px !important; height:36px !important; font-size:10px !important; }
    .step-line   { width:24px !important; }
    #step-indicator { gap:2px !important; margin-bottom:32px !important; }
  }

  /* Grids de tarjetas de negocio/servicios a 1 columna en móvil */
  @media (max-width:640px) {
    #tenants-grid  { grid-template-columns:1fr !important; }
    #services-grid { grid-template-columns:1fr !important; margin-bottom:24px !important; }
    #barbers-grid  { grid-template-columns:1fr 1fr !important; }
    #slots-grid    { grid-template-columns:repeat(auto-fill,minmax(72px,1fr)) !important; }
  }

  /* Barra sticky servicios en móvil */
  @media (max-width:640px) {
    #services-bar { flex-direction:column !important; align-items:flex-start !important; padding:12px 16px !important; gap:10px !important; }
    #svc-bar-names { max-width:100% !important; font-size:.85rem !important; }
    #services-bar > div:last-child { width:100%; justify-content:space-between !important; }
  }

  /* Summary box a 1 columna en móvil */
  @media (max-width:480px) {
    #summary-box { grid-template-columns:1fr 1fr !important; padding:16px 18px !important; gap:12px !important; }
  }

  /* Date strip botones más compactos */
  @media (max-width:480px) {
    #date-strip button { min-width:52px !important; padding:8px 4px !important; }
  }

  /* Sección hero de agendar más compacta en móvil */
  @media (max-width:640px) {
    #agendar-hero { padding:120px 16px 40px !important; }
    #agendar-hero h1 { font-size:clamp(1.8rem,6vw,3.8rem) !important; }
  }

  /* Wizard padding de sección */
  @media (max-width:640px) {
    #wizard-section { padding:36px 16px 80px !important; }
  }

  /* Tarjetas de negocio/servicio padding */
  @media (max-width:480px) {
    .tenant-card { padding:20px 16px !important; }
    .svc-card    { padding:16px 14px !important; }
    .tenant-card .t-addr { padding-left:0 !important; margin-top:8px !important; }
  }

  /* Confirmar cita box */
  @media (max-width:480px) {
    #confirm-box { padding:20px 18px !important; }
    #step-5 > div:last-of-type { flex-direction:column !important; }
    #step-5 > div:last-of-type a,
    #step-5 > div:last-of-type button { width:100% !important; justify-content:center !important; }
    #wa-notify { justify-content:center !important; width:100% !important; }
  }

  /* ── Calendario custom BookStyle ── */
  #cal-grid {
    display:grid;
    grid-template-columns:repeat(7, 1fr);
  }
  .cal-dow {
    font-family:'Work Sans',sans-serif;font-size:10px;font-weight:700;
    letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);
    text-align:center;padding:14px 0 10px;
    border-right:1px solid var(--border-light);border-bottom:1px solid var(--border-light);
  }
  .cal-dow:last-child { border-right:none; }
  .cal-cell {
    font-family:'Work Sans',sans-serif;font-size:15px;font-weight:500;
    color:var(--text-dark);text-align:center;
    padding:16px 4px;border-right:1px solid var(--border-light);border-bottom:1px solid var(--border-light);
    cursor:pointer;transition:background .15s, color .15s;
    position:relative;line-height:1;
    min-height:56px;display:flex;align-items:center;justify-content:center;
  }
  .cal-cell:last-child,.cal-cell:nth-child(7n) { border-right:none; }
  .cal-cell.cal-empty  { background:#fafafa;cursor:default; }
  .cal-cell.cal-past   { color:#ccc;background:#fafafa;cursor:not-allowed; }
  .cal-cell.cal-other  { color:#ccc; }
  .cal-cell.cal-today:not(.cal-past) { font-weight:800;color:var(--gold); }
  .cal-cell.cal-today:not(.cal-past)::after {
    content:'';position:absolute;bottom:6px;left:50%;transform:translateX(-50%);
    width:4px;height:4px;border-radius:50%;background:var(--gold);
  }
  .cal-cell:not(.cal-past):not(.cal-empty):hover {
    background:var(--cream);color:var(--gold);
  }
  .cal-cell.cal-selected:not(.cal-past) {
    background:var(--gold);color:#fff;font-weight:700;
  }
  .cal-cell.cal-selected:not(.cal-past)::after { display:none; }
  @media (max-width:480px) {
    .cal-cell  { font-size:12px;padding:10px 2px;min-height:40px; }
    .cal-dow   { font-size:8px;padding:10px 0 8px;letter-spacing:.5px; }
  }

  /* ── Slots ── */
  .slot-btn {
    height:48px;width:100%;font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;
    border:1px solid #e0dbd4;background:#fff;cursor:pointer;transition:all .2s;
    display:flex;align-items:center;justify-content:center;
  }
  .slot-btn:hover:not(:disabled):not(.occupied) { border-color:var(--gold);color:var(--gold); }
  .slot-btn.selected { background:var(--gold);color:#fff;border-color:var(--gold); }
  .slot-btn.occupied {
    background:#f2f2f2;color:#ccc;cursor:not-allowed;
    background-image:repeating-linear-gradient(-45deg,#e2e2e2 0,#e2e2e2 1px,transparent 0,transparent 6px);
    text-decoration:line-through;font-weight:400;
  }

  /* ── Category tabs ── */
  .cat-tab {
    font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    padding:7px 14px;border:1px solid #e0dbd4;background:#fff;cursor:pointer;transition:all .2s;white-space:nowrap;
  }
  .cat-tab:hover { border-color:var(--gold);color:var(--gold); }
  .cat-tab.active { background:var(--black);color:#fff;border-color:var(--black); }

  /* ── Filtro tipo de negocio ── */
  .type-tab {
    font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    padding:8px 18px;border:1.5px solid #e0dbd4;background:#fff;cursor:pointer;transition:all .2s;white-space:nowrap;
  }
  .type-tab:hover { border-color:var(--gold);color:var(--gold); }
  .type-tab.active { background:var(--black);color:#fff;border-color:var(--black); }

  /* ── Tarjeta negocio ── */
  .tenant-card {
    background:#fff;padding:28px 24px;cursor:pointer;transition:background .2s,box-shadow .2s;
    position:relative;
  }
  .tenant-card:hover:not(.selected) { background:#faf7f3; }
  .tenant-card.selected {
    background:var(--black);
    box-shadow:inset 4px 0 0 var(--gold);
  }
  .tenant-card .t-initial-bg { background:var(--gold);transition:background .2s; }
  .tenant-card.selected .t-initial-bg { background:var(--gold); }
  .tenant-card .t-name  { font-family:'Prata',serif;font-size:1.05rem;color:var(--text-dark);transition:color .2s; }
  .tenant-card.selected .t-name  { color:#fff; }
  .tenant-card .t-city  { font-family:'Work Sans',sans-serif;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--gold);margin-top:2px; }
  .tenant-card .t-addr  { font-size:13px;color:#999;margin-top:10px;padding-left:66px;transition:color .2s;overflow:hidden;text-overflow:ellipsis;white-space:nowrap; }
  .tenant-card.selected .t-addr  { color:#888; }
  .tenant-card .t-check {
    display:none;position:absolute;top:14px;right:14px;
    width:22px;height:22px;border-radius:50%;background:var(--gold);
    align-items:center;justify-content:center;
  }
  .tenant-card.selected .t-check { display:flex; }

  /* ── Tarjeta servicio ── */
  .svc-card {
    background:#fff;padding:22px 20px;cursor:pointer;transition:all .2s;position:relative;
  }
  .svc-card:hover:not(.selected) { background:#faf7f3; }
  .svc-card.selected { background:var(--black);box-shadow:inset 4px 0 0 var(--gold); }
  .svc-card .svc-cat  { font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:8px; }
  .svc-card .svc-name { font-family:'Prata',serif;font-size:1.05rem;color:var(--text-dark);margin-bottom:6px;transition:color .2s; }
  .svc-card.selected .svc-name { color:#fff; }
  .svc-card .svc-desc { font-size:13px;color:#777;line-height:1.6;margin-bottom:10px;transition:color .2s; }
  .svc-card.selected .svc-desc { color:#aaa; }
  .svc-card .svc-dur   { font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:var(--gold);transition:color .2s; }
  .svc-card.selected .svc-dur { color:#888; }
  .svc-card .svc-price { font-family:'Prata',serif;font-size:1.05rem;color:var(--text-dark);margin-left:auto;transition:color .2s; }
  .svc-card.selected .svc-price { color:#fff; }
  .svc-card .check-mark {
    position:absolute;top:12px;right:12px;width:22px;height:22px;border-radius:50%;
    background:var(--gold);display:none;align-items:center;justify-content:center;
  }
  .svc-card.selected .check-mark { display:flex; }

</style>

<script define:vars={{ API_BASE }}>
  /* ── State ─────────────────────────────────────────── */
  const state = {
    step:             0,
    tenants:          [],
    services:         [],
    barbers:          [],
    tenant:           null,
    servicesSelected: [],   // array de objetos servicio
    barber:           null,
    date:             '',
    time:             '',
    activeCat:        'Todos',
    activeType:       'ALL',
  };

  /* ── Helpers ────────────────────────────────────────── */
  const $    = id => document.getElementById(id);
  const show = (id, flex) => { $(id).style.display = flex ? 'flex' : 'block'; };
  const hide = id => { $(id).style.display = 'none'; };

  /* ── Step indicator ─────────────────────────────────── */
  function updateIndicator(step) {
    // Mapa: paso lógico → índice en indicador de 5 puntos
    // 0:Negocio, 1:Servicio, 2:Profesional, 3:Fecha, 4:Datos, 5:Confirm
    const stepToIdx = { 0:0, 1:1, 3:2, 4:3, 5:3 };
    const idx = stepToIdx[step] ?? 0;
    const labels = ['00','01','02','03'];
    document.querySelectorAll('.step-circle').forEach((el, i) => {
      const badge = el.querySelector('.step-badge');
      if (i < idx)      { el.style.background='var(--gold)';el.style.borderColor='var(--gold)';el.style.color='#fff'; el.childNodes[0].textContent='✓'; }
      else if (i===idx) { el.style.background='var(--black)';el.style.borderColor='var(--black)';el.style.color='#fff'; el.childNodes[0].textContent=labels[i]; }
      else              { el.style.background='#fff';el.style.borderColor='#ddd';el.style.color='#aaa'; el.childNodes[0].textContent=labels[i]; }
      // Badge de servicios en paso 01
      if (i === 1 && badge) {
        const count = state.servicesSelected.length;
        if (count > 0 && idx > 1) {
          badge.textContent = count;
          badge.style.display = 'flex';
        } else {
          badge.style.display = 'none';
        }
      }
    });
    document.querySelectorAll('.step-line').forEach((el, i) => {
      el.style.background = i < idx ? 'var(--gold)' : '#ddd';
    });
  }

  /* ── Navigation ─────────────────────────────────────── */
  function goTo(step) {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    for (let i = 0; i <= 5; i++) {
      const el = $(`step-${i}`);
      if (el) el.style.display = i === step ? 'block' : 'none';
    }
    state.step = step;
    updateIndicator(step);
    if (step === 1) renderServices();
    if (step === 3) renderDateStrip();
    if (step === 4) renderSummary();
  }
  window.goTo = goTo;

  /* ── Init ───────────────────────────────────────────── */
  async function initWizard() {
    hide('wiz-error');
    show('wiz-loading');
    try {
      const res = await fetch(API_BASE, { cache: 'no-store' });
      if (!res.ok) throw new Error(`Error ${res.status}`);
      const data = await res.json();
      state.tenants = data.tenants ?? [];
      hide('wiz-loading');
      renderTenants();
      goTo(0);
    } catch (e) {
      hide('wiz-loading');
      $('error-msg').textContent = e?.message ?? 'No se pudo cargar el sistema.';
      show('wiz-error');
    }
  }
  window.initWizard = initWizard;

  /* ── Paso 0: Negocios ────────────────────────────────── */
  function renderTenants(filter = '') {
    const grid = $('tenants-grid');
    const empty = $('tenants-empty');
    grid.innerHTML = '';

    const q = filter.toLowerCase().trim();
    const byText = q
      ? state.tenants.filter(t => t.name?.toLowerCase().includes(q) || t.city?.toLowerCase().includes(q))
      : state.tenants;
    const list = state.activeType === 'ALL'
      ? byText
      : byText.filter(t => t.businessType === state.activeType);

    if (state.tenants.length === 0) {
      grid.innerHTML = '<p style="padding:40px;text-align:center;color:#777;font-size:14px;background:#fff;border:2px solid var(--border-light);grid-column:1/-1;">No hay negocios disponibles en este momento.</p>';
      hide('tenants-empty');
      return;
    }

    if (list.length === 0) {
      show('tenants-empty');
      return;
    }

    hide('tenants-empty');

    list.forEach(t => {
      const card = document.createElement('div');
      card.className = 'tenant-card';
      if (state.tenant?.slug === t.slug) card.classList.add('selected');
      card.dataset.slug = t.slug;

      const initial = t.name ? t.name[0].toUpperCase() : 'B';
      card.innerHTML = `
        <div class="t-check">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div style="display:flex;align-items:center;gap:14px;">
          ${t.logoUrl
            ? `<img src="${t.logoUrl}" alt="${t.name}" style="width:52px;height:52px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
            : `<div class="t-initial-bg" style="width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1.4rem;color:#fff;">${initial}</span></div>`
          }
          <div style="min-width:0;">
            <div class="t-name">${t.name}</div>
            ${t.city ? `<div class="t-city">${t.city}</div>` : ''}
          </div>
        </div>
        ${t.address ? `<div class="t-addr">📍 ${t.address}</div>` : ''}
      `;

      card.addEventListener('click', async () => {
        grid.querySelectorAll('.tenant-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        state.tenant = t;

        const btn = $('next-0');
        btn.disabled = true;
        btn.style.opacity = '.4';
        btn.querySelector('span').textContent = 'Cargando...';

        try {
          const res = await fetch(`${API_BASE}/${t.slug}`, { cache: 'no-store' });
          if (!res.ok) throw new Error();
          const data = await res.json();
          state.services = data.services ?? [];
          state.barbers  = data.barbers  ?? [];
          state.servicesSelected = [];
          btn.disabled = false;
          btn.style.opacity = '1';
          btn.querySelector('span').textContent = 'Siguiente →';
        } catch {
          card.classList.remove('selected');
          state.tenant = null;
          btn.querySelector('span').textContent = 'Siguiente →';
          alert('No se pudo cargar la información de este negocio. Intenta de nuevo.');
        }
      });

      grid.appendChild(card);
    });
  }

  function filterTenants(val) {
    renderTenants(val);
  }
  window.filterTenants = filterTenants;

  function setTypeFilter(type) {
    state.activeType = type;
    document.querySelectorAll('.type-tab').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.type === type);
    });
    renderTenants($('search-tenant')?.value ?? '');
  }
  window.setTypeFilter = setTypeFilter;

  /* ── Banner negocio ─────────────────────────────────── */
  function renderTenantBanner() {
    if (!state.tenant) return;
    const t = state.tenant;
    const initial = t.name ? t.name[0].toUpperCase() : 'B';
    $('tenant-banner').innerHTML = `
      ${t.logoUrl
        ? `<img src="${t.logoUrl}" alt="${t.name}" style="width:36px;height:36px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
        : `<div style="width:36px;height:36px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${initial}</span></div>`
      }
      <div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);">Negocio seleccionado</div>
        <div style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${t.name}${t.city ? ` — ${t.city}` : ''}</div>
      </div>
    `;
  }

  /* ── Paso 2: Barberos ──────────────────────────────────────── */
  function renderBarbers() {
    // Copiar banner del tenant
    const t = state.tenant;
    if (!t) return;
    const initial = t.name ? t.name[0].toUpperCase() : 'B';
    $('tenant-banner-2').innerHTML = `
      ${t.logoUrl
        ? `<img src="${t.logoUrl}" alt="${t.name}" style="width:36px;height:36px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
        : `<div style="width:36px;height:36px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${initial}</span></div>`
      }
      <div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);">Negocio seleccionado</div>
        <div style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${t.name}${t.city ? ` — ${t.city}` : ''}</div>
      </div>
    `;

    const grid = $('barbers-grid');
    grid.innerHTML = '';

    // Opción "Cualquier disponible" siempre primera
    const anyCard = document.createElement('div');
    anyCard.className = 'barber-card any-barber' + (state.barber === null ? ' selected' : '');
    anyCard.innerHTML = `
      <div class="b-check">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div style="width:48px;height:48px;border-radius:50%;background:#f0ede8;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
      <div>
        <div class="b-name">Cualquier disponible</div>
        <div class="b-specs">Asignamos el profesional libre en tu horario</div>
      </div>
    `;
    anyCard.addEventListener('click', () => selectBarber(null, grid));
    grid.appendChild(anyCard);

    // Tarjeta por cada barbero
    state.barbers.forEach(b => {
      const isSelected = state.barber?.id === b.id;
      const card = document.createElement('div');
      card.className = 'barber-card' + (isSelected ? ' selected' : '');
      const specs = Array.isArray(b.specialties) && b.specialties.length > 0
        ? b.specialties.join(' · ')
        : 'Estilista profesional';
      card.innerHTML = `
        <div class="b-check">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        ${b.avatarUrl
          ? `<img src="${b.avatarUrl}" alt="${b.name}" style="width:48px;height:48px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
          : `<div style="width:48px;height:48px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1.1rem;color:#fff;">${b.name?.[0]?.toUpperCase() ?? 'B'}</span></div>`
        }
        <div style="min-width:0;">
          <div class="b-name">${b.name}</div>
          <div class="b-specs">${specs}</div>
        </div>
      `;
      card.addEventListener('click', () => selectBarber(b, grid));
      grid.appendChild(card);
    });

    // Si solo hay "cualquier disponible", activar automáticamente
    updateBarberNext();
  }

  function selectBarber(barber, grid) {
    state.barber = barber;
    grid.querySelectorAll('.barber-card').forEach(c => c.classList.remove('selected'));
    // Marcar la card correcta
    const cards = grid.querySelectorAll('.barber-card');
    if (!barber) {
      cards[0].classList.add('selected'); // "Cualquier disponible" es siempre la primera
    } else {
      cards.forEach(c => {
        const nameEl = c.querySelector('.b-name');
        if (nameEl && nameEl.textContent === barber.name) c.classList.add('selected');
      });
    }
    updateBarberNext();
  }

  function updateBarberNext() {
    // El botón siguiente se activa siempre (state.barber === null = cualquier disponible es válido)
    const btn = $('next-2');
    btn.disabled = false;
    btn.style.opacity = '1';
  }

  /* ── Paso 1: Servicios (multi-select + búsqueda + categorías) ── */
  function renderServices() {
    renderTenantBanner();
    const grid = $('services-grid');
    grid.innerHTML = '';

    // Categorías únicas
    const cats = ['Todos', ...new Set(state.services.map(s => s.category ?? 'Servicio').filter(Boolean))];
    const tabsEl = $('cat-tabs');
    tabsEl.innerHTML = '';
    cats.forEach(cat => {
      const tab = document.createElement('button');
      tab.className = 'cat-tab' + (cat === state.activeCat ? ' active' : '');
      tab.textContent = cat;
      tab.addEventListener('click', () => {
        state.activeCat = cat;
        tabsEl.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        renderServiceCards();
      });
      tabsEl.appendChild(tab);
    });

    renderServiceCards();
    updateServicesBar();
  }

  function getFilteredServices() {
    const q = ($('search-service')?.value ?? '').toLowerCase().trim();
    return state.services.filter(s => {
      const matchCat = state.activeCat === 'Todos' || (s.category ?? 'Servicio') === state.activeCat;
      const matchQ   = !q || s.name?.toLowerCase().includes(q) || s.description?.toLowerCase().includes(q);
      return matchCat && matchQ;
    });
  }

  function renderServiceCards() {
    const grid = $('services-grid');
    grid.innerHTML = '';
    const list = getFilteredServices();

    if (list.length === 0) {
      show('services-empty');
      return;
    }
    hide('services-empty');

    list.forEach(s => {
      const isSelected = state.servicesSelected.some(x => x.id === s.id);
      const card = document.createElement('div');
      card.className = 'svc-card' + (isSelected ? ' selected' : '');
      card.dataset.id = s.id;
      card.innerHTML = `
        <div class="check-mark">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="svc-cat">${s.category ?? 'Servicio'}</div>
        <div class="svc-name">${s.name}</div>
        ${s.description ? `<div class="svc-desc">${s.description}</div>` : ''}
        <div style="display:flex;gap:16px;margin-top:4px;align-items:center;">
          <span class="svc-dur">~${s.duration} min</span>
          ${s.price > 0 ? `<span class="svc-price">$${Number(s.price).toFixed(2)}</span>` : ''}
        </div>`;
      card.addEventListener('click', () => toggleService(s, card));
      grid.appendChild(card);
    });
  }

  function toggleService(s, card) {
    const idx = state.servicesSelected.findIndex(x => x.id === s.id);
    if (idx >= 0) {
      state.servicesSelected.splice(idx, 1);
      card.classList.remove('selected');
    } else {
      state.servicesSelected.push(s);
      card.classList.add('selected');
    }
    updateServicesBar();
  }

  function updateServicesBar() {
    const count = state.servicesSelected.length;
    const bar   = $('services-bar');
    const emptyNav = $('svc-nav-empty');

    if (count > 0) {
      bar.style.display = 'flex';
      hide('svc-nav-empty');
      const totalDur   = state.servicesSelected.reduce((s, x) => s + (x.duration ?? 30), 0);
      const totalPrice = state.servicesSelected.reduce((s, x) => s + (Number(x.price) || 0), 0);
      $('svc-bar-names').textContent  = state.servicesSelected.map(x => x.name).join(' · ');
      $('svc-bar-total').textContent  = totalPrice > 0 ? `$${totalPrice.toFixed(2)}` : 'A consultar';
      $('svc-bar-price').textContent  = `~${totalDur} min`;
    } else {
      bar.style.display = 'none';
      show('svc-nav-empty');
    }
  }

  function filterServices() {
    renderServiceCards();
  }
  window.filterServices = filterServices;

  /* ── Paso 3: Calendario custom ──────────────────────── */
  const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio',
                 'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const DOWS  = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];

  let calYear = 0, calMonth = 0;

  function renderDateStrip() {
    const now   = new Date();
    calYear  = now.getFullYear();
    calMonth = now.getMonth();
    state.date = '';
    state.time = '';
    const btn3 = $('next-3');
    btn3.disabled    = true;
    btn3.style.opacity = '.4';
    hide('slots-wrap');
    renderCalendar();
  }

  function calMove(delta) {
    const now = new Date();
    const ny  = calMonth + delta < 0  ? calYear - 1 : calMonth + delta > 11 ? calYear + 1 : calYear;
    const nm  = (calMonth + delta + 12) % 12;
    // No retroceder al pasado
    if (ny < now.getFullYear() || (ny === now.getFullYear() && nm < now.getMonth())) return;
    calYear  = ny;
    calMonth = nm;
    renderCalendar();
  }
  window.calMove = calMove;

  function renderCalendar() {
    const grid = $('cal-grid');
    if (!grid) return;

    // Header
    $('cal-month-name').textContent = MESES[calMonth].toUpperCase();
    $('cal-year-num').textContent   = calYear;

    // Ocultar flecha anterior si ya estamos en el mes actual
    const now = new Date();
    const isPresentMonth = calYear === now.getFullYear() && calMonth === now.getMonth();
    $('cal-prev').style.opacity = isPresentMonth ? '.25' : '.85';
    $('cal-prev').style.cursor  = isPresentMonth ? 'not-allowed' : 'pointer';

    const todayKey = dateKey(now);

    grid.innerHTML = '';

    // Cabeceras días de la semana
    DOWS.forEach(d => {
      const el = document.createElement('div');
      el.className   = 'cal-dow';
      el.textContent = d;
      grid.appendChild(el);
    });

    const firstDow    = new Date(calYear, calMonth, 1).getDay();     // 0=Dom
    const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
    const todayDate   = new Date(now.getFullYear(), now.getMonth(), now.getDate());

    // Celdas vacías antes del día 1
    for (let i = 0; i < firstDow; i++) {
      const el = document.createElement('div');
      el.className = 'cal-cell cal-empty';
      grid.appendChild(el);
    }

    // Días del mes
    for (let day = 1; day <= daysInMonth; day++) {
      const key      = `${calYear}-${pad(calMonth+1)}-${pad(day)}`;
      const cellDate = new Date(calYear, calMonth, day);
      const isPast   = cellDate < todayDate;

      const el = document.createElement('div');
      el.className   = 'cal-cell';
      el.textContent = day;

      if (isPast)           el.classList.add('cal-past');
      if (key === todayKey) el.classList.add('cal-today');
      if (key === state.date) el.classList.add('cal-selected');

      if (!isPast) {
        el.addEventListener('click', async () => {
          state.date = key;
          state.time = '';
          const btn3 = $('next-3');
          btn3.disabled = true;
          btn3.style.opacity = '.4';
          renderCalendar();        // re-render para marcar seleccionado
          await fetchSlots(key);
        });
      }

      grid.appendChild(el);
    }

    // Celdas vacías al final para completar la última fila
    const totalCells = firstDow + daysInMonth;
    const remainder  = totalCells % 7;
    if (remainder !== 0) {
      for (let i = 0; i < 7 - remainder; i++) {
        const el = document.createElement('div');
        el.className = 'cal-cell cal-empty';
        grid.appendChild(el);
      }
    }
  }

  function dateKey(d) {
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
  }
  function pad(n) { return String(n).padStart(2,'0'); }

  async function fetchSlots(date) {
    show('slots-wrap');
    $('slots-grid').style.display = 'none';
    hide('closed-msg');
    hide('slots-legend');
    show('slots-loading');
    const slug = state.tenant.slug;
    const primaryService  = state.servicesSelected[0];
    const totalDuration   = state.servicesSelected.length > 0
      ? state.servicesSelected.reduce((sum, s) => sum + (s.duration ?? 30), 0)
      : 60;
    try {
      const params = new URLSearchParams({ date, totalDuration: String(totalDuration) });
      if (primaryService) params.set('serviceId', String(primaryService.id));
      const res = await fetch(`${API_BASE}/${slug}/slots?${params}`);
      const data = await res.json();
      hide('slots-loading');
      if (!data.isOpen) {
        $('closed-msg').textContent = data.reason ?? 'No hay disponibilidad este día.';
        show('closed-msg');
        return;
      }
      renderSlots(data.slots);
    } catch {
      hide('slots-loading');
      $('closed-msg').textContent = 'No se pudieron cargar los horarios.';
      show('closed-msg');
    }
  }

  function renderSlots(slots) {
    const grid = $('slots-grid');
    grid.innerHTML = '';

    const hasAny = slots.length > 0;
    if (!hasAny) {
      $('closed-msg').textContent = 'No hay horarios disponibles para este día.';
      show('closed-msg');
      return;
    }

    slots.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'slot-btn';
      btn.textContent = s.time;

      if (!s.available) {
        btn.className += ' occupied';
        btn.disabled = true;
        btn.title = 'Horario ocupado';
      } else {
        btn.addEventListener('click', () => {
          state.time = s.time;
          grid.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          const n3 = $('next-3');
          n3.disabled = false;
          n3.style.opacity = '1';
        });
      }
      grid.appendChild(btn);
    });

    // Mostrar leyenda solo si hay slots ocupados
    const hasOccupied = slots.some(s => !s.available);
    if (hasOccupied) show('slots-legend', true);

    // CRÍTICO: usar style.display directamente para no sobrescribir con 'block'
    grid.style.display = 'grid';
  }

  /* ── Paso 4: Resumen ─────────────────────────────────── */
  function renderSummary() {
    const [y,m,d] = state.date.split('-');
    const svcNames  = state.servicesSelected.length > 0
      ? state.servicesSelected.map(s => s.name).join(', ')
      : 'A definir en el salón';
    const totalDur   = state.servicesSelected.reduce((a, s) => a + (s.duration ?? 30), 0);
    const totalPrice = state.servicesSelected.reduce((a, s) => a + (Number(s.price) || 0), 0);
    const rows = [
      { l:'Negocio',   v: state.tenant.name },
      { l:'Servicios', v: svcNames },
      { l:'Fecha',     v: `${d}/${m}/${y}` },
      { l:'Hora',      v: state.time },
    ];
    if (state.servicesSelected.length > 0) {
      rows.push({ l:'Duración estimada', v: `~${totalDur} min` });
      if (totalPrice > 0) rows.push({ l:'Total estimado', v: `$${totalPrice.toFixed(2)}` });
    }
    $('summary-box').innerHTML = rows.map(i => `
      <div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:2px;">${i.l}</div>
        <div style="font-family:'Prata',serif;font-size:.95rem;color:#fff;">${i.v}</div>
      </div>`).join('');
  }

  /* ── Submit ──────────────────────────────────────────── */
  $('booking-form').addEventListener('submit', async e => {
    e.preventDefault();
    const name  = $('f-name').value.trim();
    const phone = $('f-phone').value.trim();
    const email = $('f-email').value.trim();
    const notes = $('f-notes').value.trim();
    const errBox = $('form-error');
    errBox.style.display = 'none';

    if (name.length < 2)  { errBox.textContent='Ingresa tu nombre completo.'; errBox.style.display='block'; return; }
    if (!phone)            { errBox.textContent='El teléfono es requerido.';   errBox.style.display='block'; return; }

    const btn = $('submit-btn');
    btn.disabled = true;
    $('submit-txt').textContent = 'Confirmando...';

    const primaryService = state.servicesSelected[0];

    try {
      const res = await fetch(`${API_BASE}/${state.tenant.slug}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...(primaryService && { serviceId: primaryService.id }),
          ...(state.servicesSelected.length > 0 && { serviceIds: state.servicesSelected.map(s => s.id) }),
          barberId:     state.barber?.id ?? null,
          date:         state.date,
          time:         state.time,
          clientName:   name,
          clientPhone:  phone,
          clientEmail:  email || undefined,
          notes:        notes || undefined,
        }),
      });

      if (res.status === 429) throw new Error('Límite de reservas alcanzado. Intenta mañana.');
      if (res.status === 409) throw new Error('El horario ya no está disponible. Elige otro.');
      if (!res.ok) { const d = await res.json().catch(()=>({})); throw new Error(d?.error ?? `Error ${res.status}`); }

      const data = await res.json();
      showConfirmation(data, name);
    } catch (err) {
      errBox.textContent = err?.message ?? 'Ocurrió un error. Intenta nuevamente.';
      errBox.style.display = 'block';
      btn.disabled = false;
      $('submit-txt').textContent = 'Confirmar Cita';
    }
  });

  function showConfirmation(data, clientName) {
    const dt      = new Date(data.startTime);
    const dateStr = dt.toLocaleDateString('es-SV', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
    const timeStr = dt.toLocaleTimeString('es-SV', { hour:'2-digit', minute:'2-digit', hour12:true });
    const svcNames = state.servicesSelected.map(s => s.name).join(', ');

    $('confirm-msg').textContent = `¡${clientName}, tu cita en ${state.tenant.name} ha sido confirmada! Te esperamos el ${dateStr} a las ${timeStr}.`;

    const confirmPrice = state.servicesSelected.reduce((a, s) => a + (Number(s.price) || 0), 0);
    const confirmRows  = [
      { l:'Negocio',      v: state.tenant.name },
      { l:'Servicios',    v: svcNames },
      { l:'Profesional',  v: data.barberName },
      { l:'Fecha',        v: dateStr },
      { l:'Hora',         v: timeStr },
    ];
    if (confirmPrice > 0) confirmRows.push({ l:'Total estimado', v: `$${confirmPrice.toFixed(2)}` });
    $('confirm-box').innerHTML = confirmRows.map(i => `
      <div style="padding:10px 0;border-bottom:1px solid #333;">
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);">${i.l}</div>
        <div style="font-family:'Prata',serif;font-size:1rem;color:#fff;margin-top:2px;">${i.v}</div>
      </div>`).join('');

    // Si el backend devuelve waUrl (notificación al negocio), mostrar botón
    const waNotify = $('wa-notify');
    if (data.waUrl && waNotify) {
      waNotify.href = data.waUrl;
      waNotify.style.display = 'inline-flex';
    }
    // WhatsApp al negocio desde el cliente (confirmación personal)
    const waMsg = encodeURIComponent(`¡Hola ${state.tenant.name}! Confirmé mi cita:\n• Servicios: ${svcNames}\n• Profesional: ${data.barberName}\n• ${dateStr} a las ${timeStr}`);
      const waPhone = state.tenant.phone ? state.tenant.phone.replace(/\D/g,'') : '50366774865';
    $('confirm-wa').href = `https://wa.me/${waPhone}?text=${waMsg}`;

    $('step-indicator').style.opacity = '0.4';
    goTo(5);
  }

  /* ── Reset ───────────────────────────────────────────── */
  function resetWizard() {
    Object.assign(state, {
      step:0, servicesSelected:[], barber:null, date:'', time:'',
      tenant:null, services:[], barbers:[], activeCat:'Todos', activeType:'ALL',
    });
    ['f-name','f-phone','f-email'].forEach(id => $(id).value = '');
    $('f-notes').value = '';
    $('step-indicator').style.opacity = '1';
    const btn = $('next-0');
    btn.disabled = true;
    btn.style.opacity = '.4';
    btn.querySelector('span').textContent = 'Siguiente →';
    $('search-tenant') && ($('search-tenant').value = '');
    renderTenants();
    goTo(0);
  }
  window.resetWizard = resetWizard;

  /* ── Start ───────────────────────────────────────────── */
  initWizard();
</script>
