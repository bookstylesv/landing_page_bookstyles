---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'https://barber-pro-swart.vercel.app/api/book';
---

<Layout
  title="Agendar Cita — BookStyle"
  description="Reserva tu cita en el negocio que prefieras. Selecciona el salón o barbería, elige tu servicio y el horario disponible."
  ogImage="https://bookstyle-landing-seven.vercel.app/og-agendar.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Agendar Cita — BookStyle",
      "description": "Reserva tu cita en barberías y salones registrados en BookStyle. Selecciona negocio, servicio, profesional y horario.",
      "url": "https://bookstyle-landing-seven.vercel.app/agendar",
      "provider": {
        "@type": "Organization",
        "name": "BookStyle",
        "url": "https://bookstyle-landing-seven.vercel.app"
      },
      "potentialAction": {
        "@type": "ReserveAction",
        "target": "https://bookstyle-landing-seven.vercel.app/agendar",
        "name": "Reservar cita en línea"
      }
    })} />
  </Fragment>
  <Header />

  <!-- Hero -->
  <section id="agendar-hero" style="background:var(--black);padding:140px 24px 60px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,var(--gold) 0,var(--gold) 1px,transparent 0,transparent 50%);background-size:12px 12px;"></div>
    <div style="position:relative;z-index:2;">
      <span style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:14px;">Reservas en Línea 24/7</span>
      <h1 style="font-family:'Prata',serif;font-size:clamp(2.2rem,5vw,3.8rem);color:#fff;margin:0 0 16px;">Agenda tu <span style="color:var(--gold);">Cita</span></h1>
      <p style="font-size:15px;color:#999;max-width:480px;margin:0 auto;line-height:1.8;">Selecciona el negocio, elige el tipo de servicio y la fecha que prefieras. En minutos.</p>
    </div>
  </section>

  <!-- Wizard -->
  <section id="wizard-section" style="background:var(--cream);min-height:600px;padding:60px 24px 100px;">
    <div style="max-width:960px;margin:0 auto;">

      <!-- Indicador de pasos -->
      <div id="step-indicator" style="display:flex;align-items:center;justify-content:center;margin-bottom:48px;flex-wrap:wrap;gap:4px;">
        {[
          { n:'00', l:'Negocio' },
          { n:'01', l:'Servicio' },
          { n:'02', l:'Fecha & Hora' },
          { n:'03', l:'Tus Datos' },
        ].map((s, i) => (
          <>
            <div class="step-dot" style="display:flex;flex-direction:column;align-items:center;gap:6px;">
              <div class="step-circle" style="width:44px;height:44px;border:2px solid #ddd;display:flex;align-items:center;justify-content:center;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;color:#aaa;background:#fff;transition:all .3s;position:relative;">{s.n}
                <span class="step-badge" style="display:none;position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--gold);color:#fff;font-size:9px;font-weight:700;align-items:center;justify-content:center;"></span>
              </div>
              <span style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#aaa;">{s.l}</span>
            </div>
            {i < 3 && <div class="step-line" style="width:40px;height:1px;background:#ddd;margin-bottom:22px;flex-shrink:0;transition:background .3s;"></div>}
          </>
        ))}
      </div>

      <!-- LOADING (skeleton cards) -->
      <div id="wiz-loading" style="display:none;">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;background:#e0dbd4;">
          {Array.from({length:6}).map(() => (
            <div class="skel-card">
              <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;">
                <div class="skel skel-circle"></div>
                <div style="flex:1;">
                  <div class="skel skel-line" style="width:70%;height:16px;margin-bottom:8px;"></div>
                  <div class="skel skel-line" style="width:40%;height:12px;"></div>
                </div>
              </div>
              <div class="skel skel-line" style="width:85%;height:12px;"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- ERROR -->
      <div id="wiz-error" style="display:none;text-align:center;padding:60px 24px;background:#fff;">
        <div style="font-size:3rem;margin-bottom:16px;">⚠️</div>
        <h3 style="font-family:'Prata',serif;font-size:1.4rem;color:var(--text-dark);margin:0 0 12px;">No se pudo conectar</h3>
        <p style="color:#777;margin:0 0 24px;" id="error-msg">Error al cargar el sistema de reservas.</p>
        <button onclick="initWizard()" class="btn-gold" style="border:none;cursor:pointer;"><span>Reintentar</span></button>
      </div>

      <!-- ══ PASO 0: NEGOCIO ══ -->
      <div id="step-0" style="display:none;">
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:var(--text-dark);margin:0 0 8px;">¿A qué negocio deseas ir?</h2>
        <p style="font-size:14px;color:#777;margin:0 0 20px;">Selecciona la barbería o salón de belleza que quieres visitar.</p>

        <!-- Filtro por tipo de negocio -->
        <div id="type-tabs" style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
          <button class="type-tab active" data-type="ALL"      onclick="setTypeFilter('ALL')">Todos</button>
          <button class="type-tab"        data-type="BARBERIA" onclick="setTypeFilter('BARBERIA')">💈 Barberías</button>
          <button class="type-tab"        data-type="SALON"    onclick="setTypeFilter('SALON')">✂️ Salones</button>
        </div>

        <!-- Buscador negocios -->
        <div style="position:relative;margin-bottom:24px;max-width:460px;">
          <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="search-tenant" type="text" placeholder="Buscar por nombre o ciudad..."
            style="width:100%;height:48px;border:2px solid var(--border-light);background:#fff;padding:0 16px 0 44px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
            onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border-light)'"
            oninput="filterTenants(this.value)" />
        </div>

        <div id="tenants-empty" style="display:none;text-align:center;padding:40px;background:#fff;color:#777;font-size:14px;">
          No se encontraron negocios con ese nombre.
        </div>
        <div id="tenants-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;background:#e0dbd4;"></div>

        <div style="margin-top:32px;text-align:right;">
          <button id="next-0" onclick="goTo(1)" disabled class="btn-gold" style="border:none;cursor:pointer;opacity:.4;"><span>Siguiente →</span></button>
        </div>
      </div>

      <!-- ══ PASO 1: SERVICIO ══ -->
      <div id="step-1" style="display:none;">
        <div id="tenant-banner" style="background:var(--black);padding:14px 20px;margin-bottom:28px;display:flex;align-items:center;gap:14px;"></div>
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:var(--text-dark);margin:0 0 4px;">¿Qué tipo de servicio deseas?</h2>
        <p style="font-size:14px;color:#777;margin:0 0 20px;">Elige una o más opciones. Los precios se definen según lo que se realice en el salón.</p>

        <!-- Buscador + filtro categoría -->
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px;align-items:center;">
          <div style="position:relative;flex:1;min-width:200px;">
            <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="search-service" type="text" placeholder="Buscar servicio..."
              style="width:100%;height:44px;border:2px solid var(--border-light);background:#fff;padding:0 16px 0 44px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border-light)'"
              oninput="filterServices()" />
          </div>
          <div id="cat-tabs" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
        </div>

        <div id="services-empty" style="display:none;text-align:center;padding:40px;background:#fff;border:2px solid var(--border-light);color:#777;font-size:14px;">
          No se encontraron servicios con ese criterio.
        </div>
        <div id="services-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;background:transparent;margin-bottom:80px;"></div>

        <!-- Barra sticky de selección -->
        <div id="services-bar" style="display:none;position:sticky;bottom:0;left:0;right:0;background:var(--black);padding:16px 24px;z-index:50;box-shadow:0 -4px 24px rgba(0,0,0,.18);display:none;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
          <div>
            <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:2px;">Seleccionados</div>
            <div id="svc-bar-names" style="font-family:'Prata',serif;font-size:.95rem;color:#fff;max-width:480px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
          </div>
          <div style="display:flex;align-items:center;gap:20px;flex-shrink:0;">
            <div style="text-align:right;">
              <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);">Total est.</div>
              <div id="svc-bar-total" style="font-family:'Prata',serif;font-size:1.1rem;color:#fff;"></div>
              <div id="svc-bar-price" style="font-family:'Work Sans',sans-serif;font-size:11px;color:#888;margin-top:1px;"></div>
            </div>
            <div style="display:flex;gap:12px;">
              <button onclick="goTo(0)" style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--gold);background:none;border:1px solid var(--gold);cursor:pointer;padding:10px 16px;">← Atrás</button>
              <button id="next-1" onclick="goTo(3)" class="btn-gold" style="border:none;cursor:pointer;"><span>Siguiente →</span></button>
            </div>
          </div>
        </div>

        <!-- Nav cuando no hay selección -->
        <div id="svc-nav-empty" style="margin-top:0;display:flex;justify-content:space-between;padding-top:16px;">
          <button onclick="goTo(0)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
          <span style="font-family:'Work Sans',sans-serif;font-size:12px;color:#aaa;align-self:center;">Selecciona al menos un servicio para continuar</span>
        </div>
      </div>

      <!-- ══ PASO 3: FECHA & HORA ══ -->
      <div id="step-3" style="display:none;">
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:var(--text-dark);margin:0 0 8px;">Elige fecha y hora</h2>
        <p style="font-size:14px;color:#777;margin:0 0 24px;">Selecciona el día y horario disponible.</p>
        <!-- Calendario custom -->
        <div id="date-calendar" style="margin-bottom:32px;">
          <!-- Header: mes + flechas -->
          <div id="cal-header" style="display:flex;align-items:center;justify-content:space-between;background:var(--gold);padding:18px 20px;">
            <button id="cal-prev" onclick="calMove(-1)" aria-label="Mes anterior"
              style="background:none;border:none;cursor:pointer;color:#fff;display:flex;align-items:center;padding:4px 8px;opacity:.85;transition:opacity .2s;"
              onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.85'">
              <svg width="10" height="18" viewBox="0 0 10 18" fill="none"><polyline points="9,1 1,9 9,17" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div style="text-align:center;">
              <div id="cal-month-name" style="font-family:'Work Sans',sans-serif;font-size:14px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#fff;line-height:1;"></div>
              <div id="cal-year-num"   style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:500;color:rgba(255,255,255,.80);margin-top:3px;letter-spacing:1px;"></div>
            </div>
            <button id="cal-next" onclick="calMove(1)" aria-label="Siguiente mes"
              style="background:none;border:none;cursor:pointer;color:#fff;display:flex;align-items:center;padding:4px 8px;opacity:.85;transition:opacity .2s;"
              onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.85'">
              <svg width="10" height="18" viewBox="0 0 10 18" fill="none"><polyline points="1,1 9,9 1,17" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          <!-- Grid -->
          <div id="cal-grid" style="background:#fff;border:1.5px solid var(--border-light);border-top:none;"></div>
        </div>
        <div id="slots-wrap" style="display:none;">
          <h4 style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-dark);margin:0 0 16px;">Horarios disponibles</h4>
          <div id="slots-loading" style="display:none;text-align:center;padding:24px;">
            <div style="width:28px;height:28px;border:2px solid #eee;border-top-color:var(--gold);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto;"></div>
          </div>
          <!-- Leyenda -->
          <div id="slots-legend" style="display:none;gap:20px;margin-bottom:16px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:16px;height:16px;background:#fff;border:1px solid var(--gold);"></div>
              <span style="font-family:'Work Sans',sans-serif;font-size:11px;color:#777;">Disponible</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:16px;height:16px;background:#f5f5f5;border:1px solid #ddd;position:relative;overflow:hidden;">
                <div style="position:absolute;inset:0;background:repeating-linear-gradient(-45deg,#ddd 0,#ddd 1px,transparent 0,transparent 5px);"></div>
              </div>
              <span style="font-family:'Work Sans',sans-serif;font-size:11px;color:#777;">Ocupado</span>
            </div>
          </div>
          <div id="slots-grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:10px;"></div>
          <div id="closed-msg" style="display:none;text-align:center;padding:32px;color:#777;font-size:14px;"></div>
        </div>
        <div style="margin-top:32px;display:flex;justify-content:space-between;">
          <button onclick="goTo(1)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
          <button id="next-3" onclick="goTo(4)" disabled class="btn-gold" style="border:none;cursor:pointer;opacity:.4;"><span>Continuar →</span></button>
        </div>
      </div>

      <!-- ══ PASO 4: DATOS ══ -->
      <div id="step-4" style="display:none;">
        <div id="summary-box" style="background:var(--black);padding:24px 28px;margin-bottom:32px;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;"></div>
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:var(--text-dark);margin:0 0 8px;">Tus datos</h2>
        <p style="font-size:14px;color:#777;margin:0 0 28px;">Ingresa tus datos para confirmar la cita.</p>
        <form id="booking-form" style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;" class="form-row">
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-dark);display:block;margin-bottom:8px;">Nombre completo *</label>
              <input id="f-name" type="text" required placeholder="Tu nombre completo"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='#eee'" />
            </div>
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-dark);display:block;margin-bottom:8px;">Teléfono / WhatsApp *</label>
              <input id="f-phone" type="tel" required placeholder="+503 6677-4865"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='#eee'" />
            </div>
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-dark);display:block;margin-bottom:8px;">Email <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
            <input id="f-email" type="email" placeholder="tu@email.com"
              style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='#eee'" />
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--text-dark);display:block;margin-bottom:8px;">¿Qué te gustaría hacerte? <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
            <textarea id="f-notes" rows="3" placeholder="Describe tu estilo, el tratamiento que buscas, o cualquier preferencia especial..."
              style="width:100%;border:2px solid #eee;background:#fff;padding:12px 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;resize:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='#eee'"></textarea>
          </div>
          <div id="form-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;padding:12px 16px;font-size:14px;color:#dc2626;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
            <button type="button" onclick="goTo(3)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
            <button type="submit" id="submit-btn" class="btn-gold" style="border:none;cursor:pointer;min-width:180px;"><span id="submit-txt">Confirmar Cita</span></button>
          </div>
        </form>
      </div>

      <!-- ══ CONFIRMACIÓN ══ -->
      <div id="step-5" style="display:none;text-align:center;padding:48px 24px;">
        <div style="width:72px;height:72px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 style="font-family:'Prata',serif;font-size:2rem;color:var(--text-dark);margin:0 0 12px;">¡Cita Confirmada!</h2>
        <p style="font-size:15px;color:#777;margin:0 auto 36px;max-width:440px;" id="confirm-msg"></p>
        <div id="confirm-box" style="background:var(--black);padding:28px 32px;max-width:440px;margin:0 auto 36px;text-align:left;"></div>
        <div style="margin-bottom:16px;">
          <p style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#aaa;margin:0 0 10px;">Notifica al negocio por WhatsApp</p>
          <a id="wa-notify" href="#" target="_blank" rel="noopener noreferrer"
            style="display:none;align-items:center;gap:8px;background:#25D366;color:#fff;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:0 28px;height:52px;text-decoration:none;margin:0 auto;">
