---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'https://speeddan-barberia.vercel.app/api/book';
---

<Layout title="Agendar Cita — BookStyle" description="Reserva tu cita en el negocio que prefieras. Selecciona el salón o barbería, elige tu servicio y el horario disponible.">
  <Header />

  <!-- Hero -->
  <section style="background:#222227;padding:140px 24px 60px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,#9e8a78 0,#9e8a78 1px,transparent 0,transparent 50%);background-size:12px 12px;"></div>
    <div style="position:relative;z-index:2;">
      <span style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:#9e8a78;display:block;margin-bottom:14px;">Reservas en Línea 24/7</span>
      <h1 style="font-family:'Prata',serif;font-size:clamp(2.2rem,5vw,3.8rem);color:#fff;margin:0 0 16px;">Agenda tu <span style="color:#9e8a78;">Cita</span></h1>
      <p style="font-size:15px;color:#999;max-width:480px;margin:0 auto;line-height:1.8;">Elige el negocio que quieres visitar, selecciona tus servicios y el horario que más te convenga.</p>
    </div>
  </section>

  <!-- Wizard -->
  <section style="background:#fcf9f5;min-height:600px;padding:60px 24px 100px;">
    <div style="max-width:960px;margin:0 auto;">

      <!-- Indicador de pasos -->
      <div id="step-indicator" style="display:flex;align-items:center;justify-content:center;margin-bottom:48px;flex-wrap:wrap;gap:4px;">
        {[
          { n:'00', l:'Negocio' },
          { n:'01', l:'Servicio' },
          { n:'02', l:'Profesional' },
          { n:'03', l:'Fecha & Hora' },
          { n:'04', l:'Tus Datos' },
        ].map((s, i) => (
          <>
            <div class="step-dot" style="display:flex;flex-direction:column;align-items:center;gap:6px;">
              <div class="step-circle" style="width:44px;height:44px;border:2px solid #ddd;display:flex;align-items:center;justify-content:center;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;color:#aaa;background:#fff;transition:all .3s;position:relative;">{s.n}
                <span class="step-badge" style="display:none;position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:#9e8a78;color:#fff;font-size:9px;font-weight:700;align-items:center;justify-content:center;"></span>
              </div>
              <span style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#aaa;">{s.l}</span>
            </div>
            {i < 4 && <div class="step-line" style="width:40px;height:1px;background:#ddd;margin-bottom:22px;flex-shrink:0;transition:background .3s;"></div>}
          </>
        ))}
      </div>

      <!-- LOADING -->
      <div id="wiz-loading" style="text-align:center;padding:80px 24px;">
        <div style="width:40px;height:40px;border:3px solid #eee;border-top-color:#9e8a78;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 20px;"></div>
        <p style="font-family:'Work Sans',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#aaa;">Cargando negocios...</p>
      </div>

      <!-- ERROR -->
      <div id="wiz-error" style="display:none;text-align:center;padding:60px 24px;background:#fff;">
        <div style="font-size:3rem;margin-bottom:16px;">⚠️</div>
        <h3 style="font-family:'Prata',serif;font-size:1.4rem;color:#282828;margin:0 0 12px;">No se pudo conectar</h3>
        <p style="color:#777;margin:0 0 24px;" id="error-msg">Error al cargar el sistema de reservas.</p>
        <button onclick="initWizard()" class="btn-gold" style="border:none;cursor:pointer;"><span>Reintentar</span></button>
      </div>

      <!-- ══ PASO 0: NEGOCIO ══ -->
      <div id="step-0" style="display:none;">
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:#282828;margin:0 0 8px;">¿A qué negocio deseas ir?</h2>
        <p style="font-size:14px;color:#777;margin:0 0 24px;">Selecciona la barbería o salón de belleza que quieres visitar.</p>

        <!-- Buscador negocios -->
        <div style="position:relative;margin-bottom:24px;max-width:460px;">
          <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="search-tenant" type="text" placeholder="Buscar por nombre o ciudad..."
            style="width:100%;height:48px;border:2px solid #e8e3dc;background:#fff;padding:0 16px 0 44px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
            onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#e8e3dc'"
            oninput="filterTenants(this.value)" />
        </div>

        <div id="tenants-empty" style="display:none;text-align:center;padding:40px;background:#fff;color:#777;font-size:14px;">
          No se encontraron negocios con ese nombre.
        </div>
        <div id="tenants-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;background:#e0dbd4;"></div>

        <div style="margin-top:32px;text-align:right;">
          <button id="next-0" onclick="goTo(1)" disabled class="btn-gold" style="border:none;cursor:pointer;opacity:.4;"><span>Siguiente →</span></button>
        </div>
      </div>

      <!-- ══ PASO 1: SERVICIO ══ -->
      <div id="step-1" style="display:none;">
        <div id="tenant-banner" style="background:#222227;padding:14px 20px;margin-bottom:28px;display:flex;align-items:center;gap:14px;"></div>
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:#282828;margin:0 0 4px;">¿Qué servicios deseas?</h2>
        <p style="font-size:14px;color:#777;margin:0 0 20px;">Puedes elegir uno o más servicios.</p>

        <!-- Buscador + filtro categoría -->
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px;align-items:center;">
          <div style="position:relative;flex:1;min-width:200px;">
            <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="search-service" type="text" placeholder="Buscar servicio..."
              style="width:100%;height:44px;border:2px solid #e8e3dc;background:#fff;padding:0 16px 0 44px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#e8e3dc'"
              oninput="filterServices()" />
          </div>
          <div id="cat-tabs" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
        </div>

        <div id="services-empty" style="display:none;text-align:center;padding:40px;background:#fff;border:2px solid #e8e3dc;color:#777;font-size:14px;">
          No se encontraron servicios con ese criterio.
        </div>
        <div id="services-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;background:transparent;margin-bottom:80px;"></div>

        <!-- Barra sticky de selección -->
        <div id="services-bar" style="display:none;position:sticky;bottom:0;left:0;right:0;background:#222227;padding:16px 24px;z-index:50;box-shadow:0 -4px 24px rgba(0,0,0,.18);display:none;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
          <div>
            <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;margin-bottom:2px;">Seleccionados</div>
            <div id="svc-bar-names" style="font-family:'Prata',serif;font-size:.95rem;color:#fff;max-width:480px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
          </div>
          <div style="display:flex;align-items:center;gap:20px;flex-shrink:0;">
            <div style="text-align:right;">
              <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;">Total</div>
              <div id="svc-bar-price" style="font-family:'Prata',serif;font-size:1.1rem;color:#fff;"></div>
            </div>
            <div style="display:flex;gap:12px;">
              <button onclick="goTo(0)" style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;background:none;border:1px solid #9e8a78;cursor:pointer;padding:10px 16px;">← Atrás</button>
              <button id="next-1" onclick="goTo(2)" class="btn-gold" style="border:none;cursor:pointer;"><span>Siguiente →</span></button>
            </div>
          </div>
        </div>

        <!-- Nav cuando no hay selección -->
        <div id="svc-nav-empty" style="margin-top:0;display:flex;justify-content:space-between;padding-top:16px;">
          <button onclick="goTo(0)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
          <span style="font-family:'Work Sans',sans-serif;font-size:12px;color:#aaa;align-self:center;">Selecciona al menos un servicio</span>
        </div>
      </div>

      <!-- ══ PASO 2: PROFESIONAL ══ -->
      <div id="step-2" style="display:none;">
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:#282828;margin:0 0 8px;">¿Con quién deseas tu cita?</h2>
        <p style="font-size:14px;color:#777;margin:0 0 28px;">Elige un profesional o deja que asignemos el disponible.</p>
        <div id="barbers-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;background:transparent;margin-bottom:80px;"></div>

        <!-- Barra sticky barbero -->
        <div id="barbers-bar" style="display:none;position:sticky;bottom:0;background:#222227;padding:16px 24px;z-index:50;box-shadow:0 -4px 24px rgba(0,0,0,.18);align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
          <div>
            <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;margin-bottom:2px;">Profesional</div>
            <div id="brb-bar-name" style="font-family:'Prata',serif;font-size:.95rem;color:#fff;"></div>
          </div>
          <div style="display:flex;gap:12px;flex-shrink:0;">
            <button onclick="goTo(1)" style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;background:none;border:1px solid #9e8a78;cursor:pointer;padding:10px 16px;">← Atrás</button>
            <button id="next-2" onclick="goTo(3)" class="btn-gold" style="border:none;cursor:pointer;"><span>Siguiente →</span></button>
          </div>
        </div>

        <div id="brb-nav-empty" style="margin-top:0;display:flex;justify-content:space-between;padding-top:16px;">
          <button onclick="goTo(1)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
          <span style="font-family:'Work Sans',sans-serif;font-size:12px;color:#aaa;align-self:center;">Selecciona un profesional</span>
        </div>
      </div>

      <!-- ══ PASO 3: FECHA & HORA ══ -->
      <div id="step-3" style="display:none;">
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:#282828;margin:0 0 8px;">Elige fecha y hora</h2>
        <p style="font-size:14px;color:#777;margin:0 0 24px;">Selecciona el día y horario disponible.</p>
        <div id="date-strip" style="display:flex;gap:8px;overflow-x:auto;padding-bottom:12px;margin-bottom:32px;scrollbar-width:thin;"></div>
        <div id="slots-wrap" style="display:none;">
          <h4 style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;margin:0 0 16px;">Horarios disponibles</h4>
          <div id="slots-loading" style="display:none;text-align:center;padding:24px;">
            <div style="width:28px;height:28px;border:2px solid #eee;border-top-color:#9e8a78;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto;"></div>
          </div>
          <!-- Leyenda -->
          <div id="slots-legend" style="display:none;gap:20px;margin-bottom:16px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:16px;height:16px;background:#fff;border:1px solid #9e8a78;"></div>
              <span style="font-family:'Work Sans',sans-serif;font-size:11px;color:#777;">Disponible</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:16px;height:16px;background:#f5f5f5;border:1px solid #ddd;position:relative;overflow:hidden;">
                <div style="position:absolute;inset:0;background:repeating-linear-gradient(-45deg,#ddd 0,#ddd 1px,transparent 0,transparent 5px);"></div>
              </div>
              <span style="font-family:'Work Sans',sans-serif;font-size:11px;color:#777;">Ocupado</span>
            </div>
          </div>
          <div id="slots-grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:10px;"></div>
          <div id="closed-msg" style="display:none;text-align:center;padding:32px;color:#777;font-size:14px;"></div>
        </div>
        <div style="margin-top:32px;display:flex;justify-content:space-between;">
          <button onclick="goTo(2)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
          <button id="next-3" onclick="goTo(4)" disabled class="btn-gold" style="border:none;cursor:pointer;opacity:.4;"><span>Continuar →</span></button>
        </div>
      </div>

      <!-- ══ PASO 4: DATOS ══ -->
      <div id="step-4" style="display:none;">
        <div id="summary-box" style="background:#222227;padding:24px 28px;margin-bottom:32px;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;"></div>
        <h2 style="font-family:'Prata',serif;font-size:1.8rem;color:#282828;margin:0 0 8px;">Tus datos</h2>
        <p style="font-size:14px;color:#777;margin:0 0 28px;">Ingresa tus datos para confirmar la cita.</p>
        <form id="booking-form" style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;" class="form-row">
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Nombre completo *</label>
              <input id="f-name" type="text" required placeholder="Tu nombre completo"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
            </div>
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Teléfono / WhatsApp *</label>
              <input id="f-phone" type="tel" required placeholder="+503 0000-0000"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
            </div>
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Email <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
            <input id="f-email" type="email" placeholder="tu@email.com"
              style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Notas <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
            <textarea id="f-notes" rows="3" placeholder="Instrucciones especiales, preferencias..."
              style="width:100%;border:2px solid #eee;background:#fff;padding:12px 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;resize:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'"></textarea>
          </div>
          <div id="form-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;padding:12px 16px;font-size:14px;color:#dc2626;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
            <button type="button" onclick="goTo(3)" style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#777;background:none;border:none;cursor:pointer;padding:0;">← Anterior</button>
            <button type="submit" id="submit-btn" class="btn-gold" style="border:none;cursor:pointer;min-width:180px;"><span id="submit-txt">Confirmar Cita</span></button>
          </div>
        </form>
      </div>

      <!-- ══ CONFIRMACIÓN ══ -->
      <div id="step-5" style="display:none;text-align:center;padding:48px 24px;">
        <div style="width:72px;height:72px;background:#9e8a78;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 style="font-family:'Prata',serif;font-size:2rem;color:#282828;margin:0 0 12px;">¡Cita Confirmada!</h2>
        <p style="font-size:15px;color:#777;margin:0 auto 36px;max-width:440px;" id="confirm-msg"></p>
        <div id="confirm-box" style="background:#222227;padding:28px 32px;max-width:440px;margin:0 auto 36px;text-align:left;"></div>
        <div style="margin-bottom:16px;">
          <p style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#aaa;margin:0 0 10px;">Notifica al negocio por WhatsApp</p>
          <a id="wa-notify" href="#" target="_blank" rel="noopener noreferrer"
            style="display:none;align-items:center;gap:8px;background:#25D366;color:#fff;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:0 28px;height:52px;text-decoration:none;margin:0 auto;">
            <svg width="18" height="18" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Notificar al negocio
          </a>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
          <a id="confirm-wa" href="#" target="_blank" rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:8px;background:#fff;color:#282828;border:2px solid #e8e3dc;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:0 24px;height:48px;text-decoration:none;">
            <svg width="16" height="16" fill="#25D366" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Guardar en WhatsApp
          </a>
          <button onclick="resetWizard()" class="btn-gold" style="border:none;cursor:pointer;"><span>Nueva Cita</span></button>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (max-width:540px) { .form-row { grid-template-columns:1fr !important; } }

  /* ── Slots ── */
  .slot-btn {
    height:48px;width:100%;font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;
    border:1px solid #e0dbd4;background:#fff;cursor:pointer;transition:all .2s;
    display:flex;align-items:center;justify-content:center;
  }
  .slot-btn:hover:not(:disabled):not(.occupied) { border-color:#9e8a78;color:#9e8a78; }
  .slot-btn.selected { background:#9e8a78;color:#fff;border-color:#9e8a78; }
  .slot-btn.occupied {
    background:#f2f2f2;color:#ccc;cursor:not-allowed;
    background-image:repeating-linear-gradient(-45deg,#e2e2e2 0,#e2e2e2 1px,transparent 0,transparent 6px);
    text-decoration:line-through;font-weight:400;
  }

  /* ── Category tabs ── */
  .cat-tab {
    font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    padding:7px 14px;border:1px solid #e0dbd4;background:#fff;cursor:pointer;transition:all .2s;white-space:nowrap;
  }
  .cat-tab:hover { border-color:#9e8a78;color:#9e8a78; }
  .cat-tab.active { background:#222227;color:#fff;border-color:#222227; }

  /* ── Tarjeta negocio ── */
  .tenant-card {
    background:#fff;padding:28px 24px;cursor:pointer;transition:background .2s,box-shadow .2s;
    position:relative;
  }
  .tenant-card:hover:not(.selected) { background:#faf7f3; }
  .tenant-card.selected {
    background:#222227;
    box-shadow:inset 4px 0 0 #9e8a78;
  }
  .tenant-card .t-initial-bg { background:#9e8a78;transition:background .2s; }
  .tenant-card.selected .t-initial-bg { background:#9e8a78; }
  .tenant-card .t-name  { font-family:'Prata',serif;font-size:1.05rem;color:#282828;transition:color .2s; }
  .tenant-card.selected .t-name  { color:#fff; }
  .tenant-card .t-city  { font-family:'Work Sans',sans-serif;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#9e8a78;margin-top:2px; }
  .tenant-card .t-addr  { font-size:13px;color:#999;margin-top:10px;padding-left:66px;transition:color .2s; }
  .tenant-card.selected .t-addr  { color:#888; }
  .tenant-card .t-check {
    display:none;position:absolute;top:14px;right:14px;
    width:22px;height:22px;border-radius:50%;background:#9e8a78;
    align-items:center;justify-content:center;
  }
  .tenant-card.selected .t-check { display:flex; }

  /* ── Tarjeta servicio ── */
  .svc-card {
    background:#fff;padding:22px 20px;cursor:pointer;transition:all .2s;position:relative;
  }
  .svc-card:hover:not(.selected) { background:#faf7f3; }
  .svc-card.selected { background:#222227;box-shadow:inset 4px 0 0 #9e8a78; }
  .svc-card .svc-cat  { font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;margin-bottom:8px; }
  .svc-card .svc-name { font-family:'Prata',serif;font-size:1.05rem;color:#282828;margin-bottom:6px;transition:color .2s; }
  .svc-card.selected .svc-name { color:#fff; }
  .svc-card .svc-desc { font-size:13px;color:#777;line-height:1.6;margin-bottom:10px;transition:color .2s; }
  .svc-card.selected .svc-desc { color:#aaa; }
  .svc-card .svc-price { font-family:'Work Sans',sans-serif;font-size:13px;font-weight:700;color:#9e8a78; }
  .svc-card .svc-dur   { font-family:'Work Sans',sans-serif;font-size:12px;color:#aaa;transition:color .2s; }
  .svc-card.selected .svc-dur { color:#888; }
  .svc-card .check-mark {
    position:absolute;top:12px;right:12px;width:22px;height:22px;border-radius:50%;
    background:#9e8a78;display:none;align-items:center;justify-content:center;
  }
  .svc-card.selected .check-mark { display:flex; }

  /* ── Tarjeta barbero ── */
  .brb-card {
    background:#fff;padding:28px 16px;cursor:pointer;transition:all .2s;
    text-align:center;position:relative;
  }
  .brb-card:hover:not(.selected) { background:#faf7f3; }
  .brb-card.selected { background:#222227;box-shadow:inset 0 -4px 0 #9e8a78; }
  .brb-card .brb-name { font-family:'Prata',serif;font-size:1rem;color:#282828;margin-bottom:4px;transition:color .2s; }
  .brb-card.selected .brb-name { color:#fff; }
  .brb-card .brb-role { font-family:'Work Sans',sans-serif;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#9e8a78; }
</style>

<script define:vars={{ API_BASE }}>
  /* ── State ─────────────────────────────────────────── */
  const state = {
    step:             0,
    tenants:          [],
    services:         [],
    barbers:          [],
    tenant:           null,
    servicesSelected: [],   // array de objetos servicio
    barber:           null,
    date:             '',
    time:             '',
    activeCat:        'Todos',
  };

  /* ── Helpers ────────────────────────────────────────── */
  const $    = id => document.getElementById(id);
  const show = (id, flex) => { $(id).style.display = flex ? 'flex' : 'block'; };
  const hide = id => { $(id).style.display = 'none'; };

  /* ── Step indicator ─────────────────────────────────── */
  function updateIndicator(step) {
    const labels = ['00','01','02','03','04'];
    document.querySelectorAll('.step-circle').forEach((el, i) => {
      const badge = el.querySelector('.step-badge');
      if (i < step)      { el.style.background='#9e8a78';el.style.borderColor='#9e8a78';el.style.color='#fff'; el.childNodes[0].textContent='✓'; }
      else if (i===step) { el.style.background='#222227';el.style.borderColor='#222227';el.style.color='#fff'; el.childNodes[0].textContent=labels[i]; }
      else               { el.style.background='#fff';el.style.borderColor='#ddd';el.style.color='#aaa'; el.childNodes[0].textContent=labels[i]; }
      // Badge de servicios en paso 01
      if (i === 1 && badge) {
        const count = state.servicesSelected.length;
        if (count > 0 && step > 1) {
          badge.textContent = count;
          badge.style.display = 'flex';
        } else {
          badge.style.display = 'none';
        }
      }
    });
    document.querySelectorAll('.step-line').forEach((el, i) => {
      el.style.background = i < step ? '#9e8a78' : '#ddd';
    });
  }

  /* ── Navigation ─────────────────────────────────────── */
  function goTo(step) {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    for (let i = 0; i <= 5; i++) {
      const el = $(`step-${i}`);
      if (el) el.style.display = i === step ? 'block' : 'none';
    }
    state.step = step;
    updateIndicator(step);
    if (step === 1) renderServices();
    if (step === 2) renderBarbers();
    if (step === 3) renderDateStrip();
    if (step === 4) renderSummary();
  }
  window.goTo = goTo;

  /* ── Init ───────────────────────────────────────────── */
  async function initWizard() {
    hide('wiz-error');
    show('wiz-loading');
    try {
      const res = await fetch(API_BASE, { cache: 'no-store' });
      if (!res.ok) throw new Error(`Error ${res.status}`);
      const data = await res.json();
      state.tenants = data.tenants ?? [];
      hide('wiz-loading');
      renderTenants();
      goTo(0);
    } catch (e) {
      hide('wiz-loading');
      $('error-msg').textContent = e?.message ?? 'No se pudo cargar el sistema.';
      show('wiz-error');
    }
  }
  window.initWizard = initWizard;

  /* ── Paso 0: Negocios ────────────────────────────────── */
  function renderTenants(filter = '') {
    const grid = $('tenants-grid');
    const empty = $('tenants-empty');
    grid.innerHTML = '';

    const q = filter.toLowerCase().trim();
    const list = q
      ? state.tenants.filter(t => t.name?.toLowerCase().includes(q) || t.city?.toLowerCase().includes(q))
      : state.tenants;

    if (state.tenants.length === 0) {
      grid.innerHTML = '<p style="padding:40px;text-align:center;color:#777;font-size:14px;background:#fff;border:2px solid #e8e3dc;grid-column:1/-1;">No hay negocios disponibles en este momento.</p>';
      hide('tenants-empty');
      return;
    }

    if (list.length === 0) {
      show('tenants-empty');
      return;
    }

    hide('tenants-empty');

    list.forEach(t => {
      const card = document.createElement('div');
      card.className = 'tenant-card';
      if (state.tenant?.slug === t.slug) card.classList.add('selected');
      card.dataset.slug = t.slug;

      const initial = t.name ? t.name[0].toUpperCase() : 'B';
      card.innerHTML = `
        <div class="t-check">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div style="display:flex;align-items:center;gap:14px;">
          ${t.logoUrl
            ? `<img src="${t.logoUrl}" alt="${t.name}" style="width:52px;height:52px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
            : `<div class="t-initial-bg" style="width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1.4rem;color:#fff;">${initial}</span></div>`
          }
          <div style="min-width:0;">
            <div class="t-name">${t.name}</div>
            ${t.city ? `<div class="t-city">${t.city}</div>` : ''}
          </div>
        </div>
        ${t.address ? `<div class="t-addr">📍 ${t.address}</div>` : ''}
      `;

      card.addEventListener('click', async () => {
        grid.querySelectorAll('.tenant-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        state.tenant = t;

        const btn = $('next-0');
        btn.disabled = true;
        btn.style.opacity = '.4';
        btn.querySelector('span').textContent = 'Cargando...';

        try {
          const res = await fetch(`${API_BASE}/${t.slug}`, { cache: 'no-store' });
          if (!res.ok) throw new Error();
          const data = await res.json();
          state.services = data.services ?? [];
          state.barbers  = data.barbers  ?? [];
          state.servicesSelected = [];
          btn.disabled = false;
          btn.style.opacity = '1';
          btn.querySelector('span').textContent = 'Siguiente →';
        } catch {
          card.classList.remove('selected');
          state.tenant = null;
          btn.querySelector('span').textContent = 'Siguiente →';
          alert('No se pudo cargar la información de este negocio. Intenta de nuevo.');
        }
      });

      grid.appendChild(card);
    });
  }

  function filterTenants(val) {
    renderTenants(val);
  }
  window.filterTenants = filterTenants;

  /* ── Banner negocio ─────────────────────────────────── */
  function renderTenantBanner() {
    if (!state.tenant) return;
    const t = state.tenant;
    const initial = t.name ? t.name[0].toUpperCase() : 'B';
    $('tenant-banner').innerHTML = `
      ${t.logoUrl
        ? `<img src="${t.logoUrl}" alt="${t.name}" style="width:36px;height:36px;object-fit:cover;border-radius:50%;flex-shrink:0;" />`
        : `<div style="width:36px;height:36px;border-radius:50%;background:#9e8a78;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${initial}</span></div>`
      }
      <div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;">Negocio seleccionado</div>
        <div style="font-family:'Prata',serif;font-size:1rem;color:#fff;">${t.name}${t.city ? ` — ${t.city}` : ''}</div>
      </div>
    `;
  }

  /* ── Paso 1: Servicios (multi-select + búsqueda + categorías) ── */
  function renderServices() {
    renderTenantBanner();
    const grid = $('services-grid');
    grid.innerHTML = '';

    // Categorías únicas
    const cats = ['Todos', ...new Set(state.services.map(s => s.category ?? 'Servicio').filter(Boolean))];
    const tabsEl = $('cat-tabs');
    tabsEl.innerHTML = '';
    cats.forEach(cat => {
      const tab = document.createElement('button');
      tab.className = 'cat-tab' + (cat === state.activeCat ? ' active' : '');
      tab.textContent = cat;
      tab.addEventListener('click', () => {
        state.activeCat = cat;
        tabsEl.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        renderServiceCards();
      });
      tabsEl.appendChild(tab);
    });

    renderServiceCards();
    updateServicesBar();
  }

  function getFilteredServices() {
    const q = ($('search-service')?.value ?? '').toLowerCase().trim();
    return state.services.filter(s => {
      const matchCat = state.activeCat === 'Todos' || (s.category ?? 'Servicio') === state.activeCat;
      const matchQ   = !q || s.name?.toLowerCase().includes(q) || s.description?.toLowerCase().includes(q);
      return matchCat && matchQ;
    });
  }

  function renderServiceCards() {
    const grid = $('services-grid');
    grid.innerHTML = '';
    const list = getFilteredServices();

    if (list.length === 0) {
      show('services-empty');
      return;
    }
    hide('services-empty');

    list.forEach(s => {
      const isSelected = state.servicesSelected.some(x => x.id === s.id);
      const card = document.createElement('div');
      card.className = 'svc-card' + (isSelected ? ' selected' : '');
      card.dataset.id = s.id;
      card.innerHTML = `
        <div class="check-mark">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="svc-cat">${s.category ?? 'Servicio'}</div>
        <div class="svc-name">${s.name}</div>
        ${s.description ? `<div class="svc-desc">${s.description}</div>` : ''}
        <div style="display:flex;gap:16px;margin-top:4px;">
          <span class="svc-price">$${Number(s.price).toFixed(2)}</span>
          <span class="svc-dur">${s.duration} min</span>
        </div>`;
      card.addEventListener('click', () => toggleService(s, card));
      grid.appendChild(card);
    });
  }

  function toggleService(s, card) {
    const idx = state.servicesSelected.findIndex(x => x.id === s.id);
    if (idx >= 0) {
      state.servicesSelected.splice(idx, 1);
      card.classList.remove('selected');
    } else {
      state.servicesSelected.push(s);
      card.classList.add('selected');
    }
    updateServicesBar();
  }

  function updateServicesBar() {
    const count = state.servicesSelected.length;
    const bar   = $('services-bar');
    const emptyNav = $('svc-nav-empty');

    if (count > 0) {
      bar.style.display = 'flex';
      hide('svc-nav-empty');
      const total = state.servicesSelected.reduce((s, x) => s + Number(x.price), 0);
      $('svc-bar-names').textContent = state.servicesSelected.map(x => x.name).join(' · ');
      $('svc-bar-price').textContent = `$${total.toFixed(2)}`;
    } else {
      bar.style.display = 'none';
      show('svc-nav-empty');
    }
  }

  function filterServices() {
    renderServiceCards();
  }
  window.filterServices = filterServices;

  /* ── Paso 2: Barberos ───────────────────────────────── */
  function renderBarbers() {
    const grid = $('barbers-grid');
    grid.innerHTML = '';
    state.barber = null;
    hide('barbers-bar');
    show('brb-nav-empty');

    const makeCard = (label, sublabel, initial, value) => {
      const card = document.createElement('div');
      card.className = 'brb-card';
      card.innerHTML = `
        <div style="width:64px;height:64px;border-radius:50%;background:#9e8a78;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
          <span style="font-family:'Prata',serif;font-size:${initial.length > 1 ? '1.2rem' : '1.6rem'};color:#fff;">${initial}</span>
        </div>
        <div class="brb-name">${label}</div>
        <div class="brb-role">${sublabel}</div>`;
      card.addEventListener('click', () => {
        state.barber = value ?? 'any';
        grid.querySelectorAll('.brb-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        $('brb-bar-name').textContent = label;
        show('barbers-bar', true);
        hide('brb-nav-empty');
      });
      grid.appendChild(card);
    };

    makeCard('Cualquier disponible', 'Asignación automática', '✦', null);
    state.barbers.forEach(b => makeCard(b.name, b.specialties?.[0] ?? 'Profesional', b.name[0].toUpperCase(), b));
  }

  /* ── Paso 3: Fechas ─────────────────────────────────── */
  function renderDateStrip() {
    const strip = $('date-strip');
    strip.innerHTML = '';
    state.date = '';
    state.time = '';
    const btn3 = $('next-3');
    btn3.disabled = true;
    btn3.style.opacity = '.4';
    hide('slots-wrap');

    const today  = new Date();
    const days   = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

    for (let i = 0; i < 14; i++) {
      const d = new Date(today);
      d.setDate(today.getDate() + i);
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

      const btn = document.createElement('button');
      btn.style.cssText = 'min-width:64px;padding:10px 8px;background:#fff;border:1px solid #e0dbd4;cursor:pointer;transition:all .2s;flex-shrink:0;text-align:center;';
      btn.innerHTML = `
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#aaa;margin-bottom:4px;">${i===0?'HOY':days[d.getDay()]}</div>
        <div style="font-family:'Prata',serif;font-size:1.3rem;color:#282828;line-height:1;">${d.getDate()}</div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#9e8a78;margin-top:2px;">${months[d.getMonth()]}</div>`;
      btn.addEventListener('click', async () => {
        state.date = key;
        state.time = '';
        btn3.disabled = true;
        btn3.style.opacity = '.4';
        strip.querySelectorAll('button').forEach(b => {
          b.style.background = '#fff';
          b.style.borderColor = '#e0dbd4';
          b.querySelectorAll('div').forEach((el,j) => el.style.color = j===2 ? '#9e8a78' : j===1 ? '#282828' : '#aaa');
        });
        btn.style.background = '#222227';
        btn.style.borderColor = '#222227';
        btn.querySelectorAll('div').forEach(el => el.style.color = '#fff');
        btn.querySelectorAll('div')[2].style.color = '#9e8a78';
        await fetchSlots(key);
      });
      strip.appendChild(btn);
    }
  }

  async function fetchSlots(date) {
    show('slots-wrap');
    $('slots-grid').style.display = 'none';
    hide('closed-msg');
    hide('slots-legend');
    show('slots-loading');
    const slug = state.tenant.slug;
    const primaryService  = state.servicesSelected[0];
    const totalDuration   = state.servicesSelected.reduce((sum, s) => sum + (s.duration ?? 30), 0);
    try {
      const params = new URLSearchParams({ date, serviceId: String(primaryService.id), totalDuration: String(totalDuration) });
      if (state.barber && state.barber !== 'any') params.set('barberId', String(state.barber.id));
      const res = await fetch(`${API_BASE}/${slug}/slots?${params}`);
      const data = await res.json();
      hide('slots-loading');
      if (!data.isOpen) {
        $('closed-msg').textContent = data.reason ?? 'No hay disponibilidad este día.';
        show('closed-msg');
        return;
      }
      renderSlots(data.slots);
    } catch {
      hide('slots-loading');
      $('closed-msg').textContent = 'No se pudieron cargar los horarios.';
      show('closed-msg');
    }
  }

  function renderSlots(slots) {
    const grid = $('slots-grid');
    grid.innerHTML = '';

    const hasAny = slots.length > 0;
    if (!hasAny) {
      $('closed-msg').textContent = 'No hay horarios disponibles para este día.';
      show('closed-msg');
      return;
    }

    slots.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'slot-btn';
      btn.textContent = s.time;

      if (!s.available) {
        btn.className += ' occupied';
        btn.disabled = true;
        btn.title = 'Horario ocupado';
      } else {
        btn.addEventListener('click', () => {
          state.time = s.time;
          grid.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          const n3 = $('next-3');
          n3.disabled = false;
          n3.style.opacity = '1';
        });
      }
      grid.appendChild(btn);
    });

    // Mostrar leyenda solo si hay slots ocupados
    const hasOccupied = slots.some(s => !s.available);
    if (hasOccupied) show('slots-legend', true);

    // CRÍTICO: usar style.display directamente para no sobrescribir con 'block'
    grid.style.display = 'grid';
  }

  /* ── Paso 4: Resumen ─────────────────────────────────── */
  function renderSummary() {
    const barberName = !state.barber || state.barber === 'any' ? 'Cualquier disponible' : state.barber.name;
    const [y,m,d] = state.date.split('-');
    const svcNames = state.servicesSelected.map(s => s.name).join(', ');
    const total    = state.servicesSelected.reduce((a, s) => a + Number(s.price), 0);
    $('summary-box').innerHTML = [
      { l:'Negocio',      v: state.tenant.name },
      { l:'Servicios',    v: svcNames },
      { l:'Profesional',  v: barberName },
      { l:'Fecha',        v: `${d}/${m}/${y}` },
      { l:'Hora',         v: state.time },
      { l:'Total',        v: `$${total.toFixed(2)}` },
    ].map(i => `
      <div>
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;margin-bottom:2px;">${i.l}</div>
        <div style="font-family:'Prata',serif;font-size:.95rem;color:#fff;">${i.v}</div>
      </div>`).join('');
  }

  /* ── Submit ──────────────────────────────────────────── */
  $('booking-form').addEventListener('submit', async e => {
    e.preventDefault();
    const name  = $('f-name').value.trim();
    const phone = $('f-phone').value.trim();
    const email = $('f-email').value.trim();
    const notes = $('f-notes').value.trim();
    const errBox = $('form-error');
    errBox.style.display = 'none';

    if (name.length < 2)  { errBox.textContent='Ingresa tu nombre completo.'; errBox.style.display='block'; return; }
    if (!phone)            { errBox.textContent='El teléfono es requerido.';   errBox.style.display='block'; return; }

    const btn = $('submit-btn');
    btn.disabled = true;
    $('submit-txt').textContent = 'Confirmando...';

    const primaryService = state.servicesSelected[0];

    try {
      const res = await fetch(`${API_BASE}/${state.tenant.slug}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          serviceId:    primaryService.id,
          serviceIds:   state.servicesSelected.map(s => s.id),
          barberId:     (!state.barber || state.barber === 'any') ? null : state.barber.id,
          date:         state.date,
          time:         state.time,
          clientName:   name,
          clientPhone:  phone,
          clientEmail:  email || undefined,
          notes:        notes || undefined,
        }),
      });

      if (res.status === 429) throw new Error('Límite de reservas alcanzado. Intenta mañana.');
      if (res.status === 409) throw new Error('El horario ya no está disponible. Elige otro.');
      if (!res.ok) { const d = await res.json().catch(()=>({})); throw new Error(d?.error ?? `Error ${res.status}`); }

      const data = await res.json();
      showConfirmation(data, name);
    } catch (err) {
      errBox.textContent = err?.message ?? 'Ocurrió un error. Intenta nuevamente.';
      errBox.style.display = 'block';
      btn.disabled = false;
      $('submit-txt').textContent = 'Confirmar Cita';
    }
  });

  function showConfirmation(data, clientName) {
    const dt      = new Date(data.startTime);
    const dateStr = dt.toLocaleDateString('es-SV', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
    const timeStr = dt.toLocaleTimeString('es-SV', { hour:'2-digit', minute:'2-digit', hour12:true });
    const svcNames = state.servicesSelected.map(s => s.name).join(', ');

    $('confirm-msg').textContent = `¡${clientName}, tu cita en ${state.tenant.name} ha sido confirmada! Te esperamos el ${dateStr} a las ${timeStr}.`;

    $('confirm-box').innerHTML = [
      { l:'Negocio',      v: state.tenant.name },
      { l:'Servicios',    v: svcNames },
      { l:'Profesional',  v: data.barberName },
      { l:'Fecha',        v: dateStr },
      { l:'Hora',         v: timeStr },
    ].map(i => `
      <div style="padding:10px 0;border-bottom:1px solid #333;">
        <div style="font-family:'Work Sans',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9e8a78;">${i.l}</div>
        <div style="font-family:'Prata',serif;font-size:1rem;color:#fff;margin-top:2px;">${i.v}</div>
      </div>`).join('');

    // Si el backend devuelve waUrl (notificación al negocio), mostrar botón
    const waNotify = $('wa-notify');
    if (data.waUrl && waNotify) {
      waNotify.href = data.waUrl;
      waNotify.style.display = 'inline-flex';
    }
    // WhatsApp al negocio desde el cliente (confirmación personal)
    const waMsg = encodeURIComponent(`¡Hola ${state.tenant.name}! Confirmé mi cita:\n• Servicios: ${svcNames}\n• Profesional: ${data.barberName}\n• ${dateStr} a las ${timeStr}`);
    const waPhone = state.tenant.phone ? state.tenant.phone.replace(/\D/g,'') : '50300000000';
    $('confirm-wa').href = `https://wa.me/${waPhone}?text=${waMsg}`;

    $('step-indicator').style.opacity = '0.4';
    goTo(5);
  }

  /* ── Reset ───────────────────────────────────────────── */
  function resetWizard() {
    Object.assign(state, {
      step:0, servicesSelected:[], barber:null, date:'', time:'',
      tenant:null, services:[], barbers:[], activeCat:'Todos',
    });
    ['f-name','f-phone','f-email'].forEach(id => $(id).value = '');
    $('f-notes').value = '';
    $('step-indicator').style.opacity = '1';
    const btn = $('next-0');
    btn.disabled = true;
    btn.style.opacity = '.4';
    btn.querySelector('span').textContent = 'Siguiente →';
    $('search-tenant') && ($('search-tenant').value = '');
    renderTenants();
    goTo(0);
  }
  window.resetWizard = resetWizard;

  /* ── Start ───────────────────────────────────────────── */
  initWizard();
</script>
