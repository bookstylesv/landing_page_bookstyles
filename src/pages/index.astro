---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="BookStyle — ERP para Barberías y Salones"
  description="BookStyle es el sistema ERP para barberías y salones: agenda online, caja, inventario, clientes y reportes. Empieza hoy."
>
  <Header />

  <!-- ═══════════════════════════════════════
       HERO CAROUSEL (estilo Web_Agricultura)
       Cada slide = fondo completo + tag + h1 + p + CTAs
  ══════════════════════════════════════════ -->
  <section id="inicio" class="hero-carousel-section">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {[
          { src: 'https://images.unsplash.com/photo-1585747860715-2ba37e788b70?w=1600&auto=format&fit=crop&q=80', tag: 'Sistema ERP Profesional', h1: 'El sistema que necesita<br>tu <em>barbería o salón</em>', p: 'BookStyle centraliza tu agenda, caja, inventario y clientes en un solo panel. Simple. Sin complicaciones.' },
          { src: 'https://images.unsplash.com/photo-1560066984-138daaa7fd3c?w=1600&auto=format&fit=crop&q=80', tag: 'Agenda Online 24/7', h1: 'Tus clientes agendan<br><em>cuando quieran</em>', p: 'Sin llamadas perdidas. Reservas en tiempo real desde cualquier dispositivo, a cualquier hora.' },
          { src: 'https://images.unsplash.com/photo-1599351431202-1e0f0137899a?w=1600&auto=format&fit=crop&q=80', tag: 'Control de Caja', h1: 'Ventas y cierre de caja<br><em>en segundos</em>', p: 'Registra ventas, métodos de pago y comisiones por profesional. Historial completo cada día.' },
          { src: 'https://images.unsplash.com/photo-1622286342621-4bd786c2447c?w=1600&auto=format&fit=crop&q=80', tag: 'Menos Papeles, Más Cortes', h1: 'Más tiempo cortando,<br><em>menos en papeles</em>', p: 'Deja de perder tiempo en administración manual. BookStyle automatiza todo por ti.' },
          { src: 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=1600&auto=format&fit=crop&q=80', tag: 'Spa & Wellness', h1: 'Para spas, salones<br><em>y centros de belleza</em>', p: 'BookStyle se adapta a cualquier tipo de negocio de belleza y bienestar.' },
          { src: 'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=1600&auto=format&fit=crop&q=80', tag: 'Negocio Profesional', h1: 'Tu negocio merece un<br><em>sistema profesional</em>', p: 'Sin contratos largos ni letra pequeña. Solo herramientas que realmente funcionan.' },
          { src: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1600&auto=format&fit=crop&q=80', tag: 'Gestión Moderna', h1: 'Gestión moderna para<br><em>negocios exitosos</em>', p: 'Desde el primer cliente hasta el cierre del día, todo bajo control en un panel.' },
          { src: 'https://images.unsplash.com/photo-1604654894610-df63bc536371?w=1600&auto=format&fit=crop&q=80', tag: 'Inventario Inteligente', h1: 'Inventario siempre<br><em>bajo control</em>', p: 'Alertas de reorden automáticas, compras a proveedores y stock en tiempo real.' },
          { src: 'https://images.unsplash.com/photo-1562322140-8baeececf3df?w=1600&auto=format&fit=crop&q=80', tag: 'Clientes Fieles', h1: 'Clientes que vuelven<br><em>una y otra vez</em>', p: 'Historial de visitas, preferencias y notas personalizadas para cada cliente.' },
          { src: 'https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=1600&auto=format&fit=crop&q=80', tag: 'Analytics en Tiempo Real', h1: 'Reportes y métricas<br><em>en tiempo real</em>', p: 'Conoce tus servicios más populares, ingresos y el rendimiento de tu equipo.' },
          { src: 'https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=1600&auto=format&fit=crop&q=80', tag: 'Gestión de Equipo', h1: 'Tu equipo siempre<br><em>organizado</em>', p: 'Agenda por profesional, control de comisiones y planilla en un solo lugar.' },
          { src: 'https://images.unsplash.com/photo-1582095133179-bfd08e2585d8?w=1600&auto=format&fit=crop&q=80', tag: 'Sin Comisiones por Cita', h1: 'Precio fijo mensual,<br><em>sin sorpresas</em>', p: 'Agenda todas las citas que quieras. Nunca cobraremos comisión por cada reserva.' },
          { src: 'https://images.unsplash.com/photo-1470259078422-826894b933aa?w=1600&auto=format&fit=crop&q=80', tag: 'Onboarding Rápido', h1: 'Listo en menos de<br><em>24 horas</em>', p: 'Te acompañamos en cada paso de la configuración para que empieces a funcionar rápido.' },
          { src: 'https://images.unsplash.com/photo-1519415387722-a1c3bbef716c?w=1600&auto=format&fit=crop&q=80', tag: 'Soporte en Español', h1: 'Soporte humano<br><em>en tu idioma</em>', p: 'Atención personalizada para barberías y salones en El Salvador y Latinoamérica.' },
          { src: 'https://images.unsplash.com/photo-1634449571010-02389ed0f9b0?w=1600&auto=format&fit=crop&q=80', tag: 'Demo Gratuita', h1: 'Empieza hoy con<br><em>una demo gratuita</em>', p: 'Conoce el sistema completo en acción. Sin compromiso. Sin tarjeta de crédito.' },
          { src: 'https://images.unsplash.com/photo-1600334129128-685c5582fd35?w=1600&auto=format&fit=crop&q=80', tag: 'Únete a BookStyle', h1: 'Cientos de negocios<br><em>ya confían en nosotros</em>', p: 'Únete a la comunidad de barberías y salones que ya transformaron su gestión.' },
        ].map(slide => (
          <div class="swiper-slide hero-slide" style={`background-image:url('${slide.src}')`}>
            <div class="hero-slide-overlay">
              <span class="hero-slide-tag">{slide.tag}</span>
              <h1 set:html={slide.h1}></h1>
              <p>{slide.p}</p>
              <div class="hero-ctas" style="display:flex;flex-wrap:wrap;gap:14px;">
                <a href="#contacto" class="btn-gold" style="text-decoration:none;"><span>Solicitar Demo</span></a>
                <a href="/agendar" class="btn-outline" style="text-decoration:none;">Ver Booking en vivo</a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="swiper-button-prev hero-nav-btn"></div>
      <div class="swiper-button-next hero-nav-btn"></div>
      <div class="swiper-pagination hero-pagination"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BARRA DE MÓDULOS
  ══════════════════════════════════════════ -->
  <section style="background:var(--black);padding:20px 0;overflow:hidden;">
    <div class="modules-bar" style="max-width:1200px;margin:0 auto;padding:0 16px;gap:0;">
      {[
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, label: 'Agenda Online' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`, label: 'Caja / POS' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`, label: 'Inventario' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Clientes' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, label: 'Reportes' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>`, label: 'Equipo' },
      ].map(m => (
        <div class="module-item" style="display:flex;align-items:center;gap:10px;padding:10px 24px;border-right:1px solid #222;">
          <Fragment set:html={m.icon} />
          <span style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#666;">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FEATURES DEL ERP
  ══════════════════════════════════════════ -->
  <section id="features" class="section-pad" style="padding:100px 24px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:48px;" data-aos="fade-up">
        <span class="section-label">Todo lo que necesitas</span>
        <h2 class="section-title" style="margin:0 auto;">Módulos del sistema</h2>
        <div class="section-divider center"></div>
        <p style="max-width:520px;margin:0 auto;font-size:15px;line-height:1.9;">
          Un solo sistema con todo lo que tu negocio necesita para funcionar de manera profesional.
        </p>
      </div>

      <div class="cards-grid-320">
        {[
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
            nombre: 'Agenda Online',
            desc: 'Tus clientes agendan citas 24/7 desde su teléfono. Sin llamadas, sin malentendidos. Recordatorios automáticos por WhatsApp.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="6.01" y2="15" stroke-linecap="round" stroke-width="2"/><line x1="10" y1="15" x2="14" y2="15" stroke-linecap="round"/></svg>`,
            nombre: 'Control de Caja / POS',
            desc: 'Registra ventas, métodos de pago y cierre de caja diario. Historial completo de ingresos y comisiones por barbero.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
            nombre: 'Inventario & Compras',
            desc: 'Controla tu stock de productos, alertas de reorden y órdenes de compra a proveedores. Nunca te quedes sin insumos.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
            nombre: 'Gestión de Clientes',
            desc: 'Historial de visitas, preferencias y notas por cliente. Retención y fidelización con datos reales de tu negocio.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
            nombre: 'Reportes & Analytics',
            desc: 'Ingresos diarios, semanales y mensuales. Servicios más populares, desempeño por profesional y tendencias de tu negocio.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="19" cy="6" r="3"/><path d="M22 9h-3.5"/></svg>`,
            nombre: 'Gestión de Equipo',
            desc: 'Agenda por profesional, control de comisiones y planilla. Todo lo que necesitas para administrar tu equipo sin dolor de cabeza.',
          },
        ].map((f, i) => (
          <div class="feature-card card-pad-lg" style="background:#fff;padding:44px 36px;position:relative;overflow:hidden;"
            data-aos="fade-up" data-aos-delay={String(i * 80)}>
            <div style="position:absolute;top:0;left:0;width:3px;height:0;background:var(--gold);transition:height .4s ease;" class="feature-accent"></div>
            <Fragment set:html={f.icon} />
            <h3 style="font-family:'Prata',serif;font-size:1.25rem;color:var(--text-dark);margin:20px 0 10px;">{f.nombre}</h3>
            <p style="font-size:14px;line-height:1.8;color:var(--text-muted);margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       DEMO DEL BOOKING
  ══════════════════════════════════════════ -->
  <section id="demo" class="section-pad" style="padding:100px 24px;background:var(--cream);">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:60px;" data-aos="fade-up">
        <span class="section-label">Para tus clientes</span>
        <h2 class="section-title" style="margin:0 auto;">Tus clientes agendan en 3 pasos simples</h2>
        <div class="section-divider center"></div>
        <p style="max-width:500px;margin:0 auto;font-size:15px;line-height:1.9;">
          Sin apps que instalar, sin registros complicados. Solo entran, eligen y confirman.
        </p>
      </div>

      <div class="cards-grid-260" style="margin-bottom:40px;">
        {[
          {
            n: '01',
            titulo: 'Elige el negocio',
            desc: 'El cliente busca tu barbería o salón por nombre. Ve tu información y servicios disponibles.',
          },
          {
            n: '02',
            titulo: 'Selecciona fecha y hora',
            desc: 'Elige el tipo de servicio y el horario disponible en tiempo real. Sin llamadas ni esperas.',
          },
          {
            n: '03',
            titulo: 'Confirma la cita',
            desc: 'Ingresa su nombre y teléfono. La cita queda registrada al instante en tu panel de administración.',
          },
        ].map((step, i) => (
          <div class="card-pad-lg" style="background:#fff;padding:44px 36px;"
            data-aos="fade-up" data-aos-delay={String(i * 150)}>
            <div style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:20px;">{step.n}</div>
            <h3 style="font-family:'Prata',serif;font-size:1.35rem;color:var(--text-dark);margin:0 0 14px;">{step.titulo}</h3>
            <p style="font-size:14px;line-height:1.8;color:var(--text-muted);margin:0;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center;" data-aos="fade-up">
        <a href="/agendar" class="btn-gold" style="text-decoration:none;"><span>Probar el booking ahora →</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       POR QUÉ BOOKSTYLE
  ══════════════════════════════════════════ -->
  <section class="section-pad" style="padding:100px 24px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;" class="about-grid">
      <!-- Imagen -->
      <div class="about-img-wrap" style="position:relative;padding-bottom:40px;" data-aos="fade-right">
        <img
          src="https://images.unsplash.com/photo-1599351431202-1e0f0137899a?w=640&auto=format&fit=crop&q=80"
          alt="Barbero trabajando con BookStyle"
          class="about-img"
          style="width:80%;aspect-ratio:3/4;object-fit:cover;box-shadow:0 16px 40px rgba(0,0,0,.18);"
        />
        <div class="about-overlay-box" style="position:absolute;bottom:0;right:0;background:var(--black);padding:22px 28px;max-width:220px;">
          <div style="font-family:'Prata',serif;font-size:2rem;color:var(--gold);line-height:1;">Todo</div>
          <div style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#fff;margin-top:6px;">en un solo sistema</div>
        </div>
      </div>

      <!-- Texto -->
      <div data-aos="fade-left">
        <span class="section-label">¿Por qué BookStyle?</span>
        <h2 class="section-title">Hecho para barberías y salones reales</h2>
        <div class="section-divider"></div>
        <div style="display:flex;flex-direction:column;gap:20px;margin-bottom:40px;">
          {[
            { icon: '✓', titulo: 'Todo en uno', desc: 'Sin necesidad de usar 3 apps diferentes para agenda, caja e inventario.' },
            { icon: '✓', titulo: 'Sin comisiones por cita', desc: 'Precio fijo mensual. Puedes agendar todas las citas que quieras.' },
            { icon: '✓', titulo: 'Soporte en español', desc: 'Para barberías y salones en El Salvador y Latinoamérica.' },
            { icon: '✓', titulo: 'Tus datos, bajo tu control', desc: 'No compartimos tu información con competidores.' },
            { icon: '✓', titulo: 'Setup en menos de 24 horas', desc: 'Te ayudamos a configurar tu cuenta y migrar tu información.' },
          ].map(b => (
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <div style="width:28px;height:28px;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
                <span style="color:#fff;font-weight:700;font-size:14px;">{b.icon}</span>
              </div>
              <div>
                <div style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:700;color:var(--text-dark);margin-bottom:3px;">{b.titulo}</div>
                <div style="font-size:14px;color:var(--text-muted);line-height:1.6;">{b.desc}</div>
              </div>
            </div>
          ))}
        </div>
        <a href="#contacto" class="btn-gold" style="text-decoration:none;"><span>Solicitar Demo</span></a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       TESTIMONIALES
  ══════════════════════════════════════════ -->
  <section id="testimoniales" class="section-pad" style="padding:100px 24px;background:var(--cream);">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:60px;" data-aos="fade-up">
        <span class="section-label">Lo que dicen nuestros clientes</span>
        <h2 class="section-title" style="margin:0 auto;">Negocios que confían en BookStyle</h2>
        <div class="section-divider center"></div>
      </div>

      <div class="cards-grid-320" style="background:var(--cream-border);">
        {[
          {
            inicial: 'C',
            nombre: 'Carlos Molina',
            negocio: 'BarberKing',
            ciudad: 'San Salvador',
            texto: 'Desde que usamos BookStyle dejamos de perder citas por llamadas perdidas. Todo lo gestionamos desde el panel y los clientes pueden agendar solos. Un antes y un después.',
          },
          {
            inicial: 'L',
            nombre: 'Lorena Gutiérrez',
            negocio: 'Salón Élite',
            ciudad: 'Santa Ana',
            texto: 'El control de caja y el inventario me ahorran horas cada semana. Antes llevaba todo en papel. Ahora en dos clicks sé cuánto ingresé y qué productos me están faltando.',
          },
          {
            inicial: 'R',
            nombre: 'Roberto Escalante',
            negocio: 'Cortes & Style',
            ciudad: 'San Miguel',
            texto: 'Lo mejor es que mis clientes pueden ver horarios disponibles y agendar sin molestarme. Me llega la notificación y ya está. BookStyle cambió cómo trabajo.',
          },
        ].map((t, i) => (
          <div class="card-pad-lg" style="background:#fff;padding:44px 36px;"
            data-aos="zoom-in" data-aos-delay={String(i * 100)}>
            <div style="font-family:'Prata',serif;font-size:3rem;color:var(--cream-dark);line-height:1;margin-bottom:16px;">"</div>
            <p style="font-size:15px;line-height:1.9;color:var(--text-dark-alt);margin:0 0 28px;">{t.texto}</p>
            <div style="display:flex;align-items:center;gap:14px;">
              <div style={`width:48px;height:48px;border-radius:50%;background:${i%2===0?'var(--black)':'var(--gold)'};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                <span style="font-family:'Prata',serif;font-size:1.3rem;color:#fff;">{t.inicial}</span>
              </div>
              <div>
                <div style="font-family:'Prata',serif;font-size:1rem;color:var(--text-dark);">{t.nombre}</div>
                <div style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--gold);">{t.negocio} · {t.ciudad}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PRECIOS
  ══════════════════════════════════════════ -->
  <section id="precios" class="section-pad" style="background:var(--black-deep);padding:100px 24px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,var(--gold) 0,var(--gold) 1px,transparent 0,transparent 50%);background-size:12px 12px;"></div>
