  <Footer />
</Layout>

<style>
  @keyframes pulse { 0%,100%{opacity:.5} 50%{opacity:1} }
  .feature-card:hover .feature-accent { height: 100% !important; }

  /* ── Módulos bar: scroll horizontal en móvil ── */
  .modules-bar { display:flex; flex-wrap:wrap; justify-content:center; }
  @media (max-width: 640px) {
    .modules-bar {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 2px;
    }
    .modules-bar::-webkit-scrollbar { display: none; }
    .module-item { flex-shrink: 0; padding: 10px 16px !important; }
  }

  /* ── Secciones padding reducido en móvil ── */
  @media (max-width: 768px) {
    .section-pad { padding: 60px 20px !important; }
    .about-grid, .contact-grid { grid-template-columns: 1fr !important; gap: 36px !important; }
    .form-row { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 480px) {
    .section-pad { padding: 48px 16px !important; }
  }

  /* ── Hero ── */
  @media (max-width: 768px) {
    .hero-content { padding-top: 60px !important; padding-left: 20px !important; padding-right: 20px !important; }
  }

  /* ── Grids de cards (features, demo, testimoniales, precios) ── */
  .cards-grid-320 { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:2px; background:#f0ebe3; }
  .cards-grid-260 { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:2px; background:#e0dbd4; }
  .cards-grid-240 { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr));  gap:2px; }
  @media (max-width: 700px) {
    .cards-grid-320, .cards-grid-260, .cards-grid-240 {
      grid-template-columns: 1fr !important;
    }
  }

  /* ── Card padding reducido en móvil ── */
  .card-pad-lg { padding: 44px 36px; }
  @media (max-width: 640px) {
    .card-pad-lg { padding: 28px 22px !important; }
  }

  /* ── Imagen about en móvil ── */
  @media (max-width: 768px) {
    .about-img { width: 100% !important; }
    .about-overlay-box { position: relative !important; margin-top: 20px; right: auto !important; bottom: auto !important; max-width: 100% !important; }
    .about-img-wrap { padding-bottom: 0 !important; }
  }

  /* ── Formulario contacto en móvil ── */
  @media (max-width: 640px) {
    .contact-form-box { padding: 28px 20px !important; }
  }

  /* ── Precios cards ── */
  @media (max-width: 860px) {
    .price-cards-wrap { grid-template-columns: 1fr !important; max-width: 420px !important; }
  }
  @media (min-width: 861px) and (max-width: 1060px) {
    .price-cards-wrap { grid-template-columns: repeat(3,1fr) !important; }
  }

  /* ── Beneficios bullets ── */
  @media (max-width: 480px) {
    .benefit-icon { width: 24px !important; height: 24px !important; flex-shrink: 0; }
  }

  /* ── CTAs hero flex-wrap ── */
  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column !important; align-items: flex-start; }
    .hero-ctas a { width: 100%; text-align: center; }
  }
</style>

<script>
  /* ── Formulario lead → WhatsApp ── */
  const BOOKSTYLE_WA = '50300000000'; // TODO: reemplazar con número real de WhatsApp de BookStyle

  document.getElementById('demo-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const nombre  = (document.getElementById('lead-nombre') as HTMLInputElement).value.trim();
    const tel     = (document.getElementById('lead-tel') as HTMLInputElement).value.trim();
    const negocio = (document.getElementById('lead-negocio') as HTMLInputElement).value.trim();
    const ciudad  = (document.getElementById('lead-ciudad') as HTMLInputElement).value.trim();
    const mensaje = (document.getElementById('lead-mensaje') as HTMLTextAreaElement).value.trim();
    const errBox  = document.getElementById('form-error') as HTMLElement;

    if (!nombre || !tel || !negocio) {
      errBox.textContent = 'Por favor completa los campos requeridos.';
      errBox.style.display = 'block';
      return;
    }
    errBox.style.display = 'none';

    const lines = [
      '¡Hola BookStyle! Quiero solicitar una demo del sistema.',
      `👤 Nombre: ${nombre}`,
      `🏪 Negocio: ${negocio}`,
      ciudad ? `📍 Ciudad: ${ciudad}` : '',
      `📱 Contacto: ${tel}`,
      mensaje ? `💬 Mensaje: ${mensaje}` : '',
    ].filter(Boolean).join('\n');

    window.open(`https://wa.me/${BOOKSTYLE_WA}?text=${encodeURIComponent(lines)}`, '_blank');
  });
</script>
