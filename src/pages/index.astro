<script is:inline>
  /* ── Swiper Hero Carousel ──
     is:inline mantiene el script en posición en el HTML.
     DOMContentLoaded se dispara DESPUÉS de los scripts sincrónicos CDN.
     effect: 'fade' = crossfade suave entre slides fullscreen (estilo Web_Agricultura).
  */
  document.addEventListener('DOMContentLoaded', function () {
    if (window.Swiper) {
      new window.Swiper('.hero-swiper', {
        loop: true,
        slidesPerView: 1,
        spaceBetween: 0,
        speed: 900,
        autoplay: {
          delay: 3800,
          disableOnInteraction: false,
        },
        navigation: {
          prevEl: '.swiper-button-prev.hero-nav-btn',
          nextEl: '.swiper-button-next.hero-nav-btn',
        },
        pagination: {
          el: '.hero-pagination',
          clickable: true,
          dynamicBullets: true,
        },
      });
    }
  });

</script>

<script>
  /* ── Formulario lead → WhatsApp ── */
  const BOOKSTYLE_WA = '50300000000'; // TODO: reemplazar con número real de WhatsApp de BookStyle

  document.getElementById('demo-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const nombre  = (document.getElementById('lead-nombre') as HTMLInputElement).value.trim();
    const tel     = (document.getElementById('lead-tel') as HTMLInputElement).value.trim();
    const negocio = (document.getElementById('lead-negocio') as HTMLInputElement).value.trim();
    const ciudad  = (document.getElementById('lead-ciudad') as HTMLInputElement).value.trim();
    const mensaje = (document.getElementById('lead-mensaje') as HTMLTextAreaElement).value.trim();
    const errBox  = document.getElementById('form-error') as HTMLElement;

    if (!nombre || !tel || !negocio) {
      errBox.textContent = 'Por favor completa los campos requeridos.';
      errBox.style.display = 'block';
      return;
    }
    errBox.style.display = 'none';

    const lines = [
      '¡Hola BookStyle! Quiero solicitar una demo del sistema.',
      `👤 Nombre: ${nombre}`,
      `🏪 Negocio: ${negocio}`,
      ciudad ? `📍 Ciudad: ${ciudad}` : '',
      `📱 Contacto: ${tel}`,
      mensaje ? `💬 Mensaje: ${mensaje}` : '',
    ].filter(Boolean).join('\n');

    window.open(`https://wa.me/${BOOKSTYLE_WA}?text=${encodeURIComponent(lines)}`, '_blank');
  });
</script>
