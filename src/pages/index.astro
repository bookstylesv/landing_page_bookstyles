                <a href={c.href} style="font-size:15px;color:#282828;text-decoration:none;">{c.val}</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Formulario lead → WhatsApp -->
      <div class="contact-form-box" style="background:#fcf9f5;padding:48px 40px;">
        <h3 style="font-family:'Prata',serif;font-size:1.5rem;color:#282828;margin:0 0 28px;">Cuéntanos sobre tu negocio</h3>
        <form id="demo-form" style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;" class="form-row">
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Nombre *</label>
              <input id="lead-nombre" type="text" required placeholder="Tu nombre"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
            </div>
            <div>
              <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">WhatsApp *</label>
              <input id="lead-tel" type="tel" required placeholder="+503 0000-0000"
                style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
                onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
            </div>
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Nombre del negocio *</label>
            <input id="lead-negocio" type="text" required placeholder="Tu Barbería o Salón"
              style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Ciudad</label>
            <input id="lead-ciudad" type="text" placeholder="San Salvador"
              style="width:100%;height:52px;border:2px solid #eee;background:#fff;padding:0 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'" />
          </div>
          <div>
            <label style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#282828;display:block;margin-bottom:8px;">Mensaje <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
            <textarea id="lead-mensaje" rows="3" placeholder="¿Qué quieres gestionar? ¿Tienes alguna duda?"
              style="width:100%;border:2px solid #eee;background:#fff;padding:12px 16px;font-family:'Lato',sans-serif;font-size:14px;outline:none;resize:none;transition:border-color .3s;box-sizing:border-box;"
              onfocus="this.style.borderColor='#9e8a78'" onblur="this.style.borderColor='#eee'"></textarea>
          </div>
          <div id="form-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;padding:12px 16px;font-size:14px;color:#dc2626;"></div>
          <button type="submit" class="btn-gold" style="width:100%;cursor:pointer;border:none;">
            <span>Enviar por WhatsApp →</span>
          </button>
          <p style="font-size:12px;color:#aaa;text-align:center;margin:0;">Al enviar abrirá WhatsApp con tu información pre-llenada.</p>
        </form>
