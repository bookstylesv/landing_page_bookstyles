---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="BookStyle — ERP para Barberías y Salones"
  description="BookStyle es el sistema ERP para barberías y salones: agenda online, caja, inventario, clientes y reportes. Empieza hoy."
>
  <Header />

  <!-- ═══════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section id="inicio" style="position:relative;height:100vh;min-height:600px;display:flex;align-items:center;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1585747860715-2ba37e788b70?w=1600&auto=format&fit=crop&q=80');background-size:cover;background-position:center;transform:scale(1.05);transition:transform 8s ease;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(to right, rgba(22,22,27,.92) 55%, rgba(22,22,27,.6));"></div>

    <div class="hero-content" style="position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:80px 24px 0;">
      <span class="section-label fade-up">Sistema ERP para Barberías y Salones</span>
      <h1 class="fade-up delay-1" style="font-family:'Prata',serif;font-size:clamp(2rem,5.5vw,4.6rem);color:#fff;line-height:1.1;margin:0 0 24px;max-width:700px;">
        El sistema que necesita<br>tu <span style="color:#9e8a78;">barbería o salón</span>
      </h1>
      <p class="fade-up delay-2" style="font-size:clamp(14px,2.5vw,16px);color:#ddd;max-width:500px;line-height:1.9;margin:0 0 40px;">
        BookStyle centraliza tu agenda, caja, inventario, clientes y equipo en un solo panel. Simple. Sin complicaciones.
      </p>
      <div class="fade-up delay-3 hero-ctas" style="display:flex;flex-wrap:wrap;gap:14px;">
        <a href="#contacto" class="btn-gold" style="text-decoration:none;"><span>Solicitar Demo</span></a>
        <a href="/agendar" class="btn-outline" style="text-decoration:none;">Ver Booking en vivo</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BARRA DE MÓDULOS
  ══════════════════════════════════════════ -->
  <section style="background:#222227;padding:20px 0;overflow:hidden;">
    <div class="modules-bar" style="max-width:1200px;margin:0 auto;padding:0 16px;gap:0;">
      {[
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, label: 'Agenda Online' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`, label: 'Caja / POS' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`, label: 'Inventario' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Clientes' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, label: 'Reportes' },
        { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>`, label: 'Equipo' },
      ].map(m => (
        <div class="module-item" style="display:flex;align-items:center;gap:10px;padding:10px 24px;border-right:1px solid #333;">
          <Fragment set:html={m.icon} />
          <span style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#999;">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FEATURES DEL ERP
  ══════════════════════════════════════════ -->
  <section id="features" class="section-pad" style="padding:100px 24px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:48px;">
        <span class="section-label">Todo lo que necesitas</span>
        <h2 class="section-title" style="margin:0 auto;">Módulos del sistema</h2>
        <div class="section-divider center"></div>
        <p style="max-width:520px;margin:0 auto;font-size:15px;line-height:1.9;">
          Un solo sistema con todo lo que tu negocio necesita para funcionar de manera profesional.
        </p>
      </div>

      <div class="cards-grid-320">
        {[
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
            nombre: 'Agenda Online',
            desc: 'Tus clientes agendan citas 24/7 desde su teléfono. Sin llamadas, sin malentendidos. Recordatorios automáticos por WhatsApp.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="6.01" y2="15" stroke-linecap="round" stroke-width="2"/><line x1="10" y1="15" x2="14" y2="15" stroke-linecap="round"/></svg>`,
            nombre: 'Control de Caja / POS',
            desc: 'Registra ventas, métodos de pago y cierre de caja diario. Historial completo de ingresos y comisiones por barbero.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
            nombre: 'Inventario & Compras',
            desc: 'Controla tu stock de productos, alertas de reorden y órdenes de compra a proveedores. Nunca te quedes sin insumos.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
            nombre: 'Gestión de Clientes',
            desc: 'Historial de visitas, preferencias y notas por cliente. Retención y fidelización con datos reales de tu negocio.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
            nombre: 'Reportes & Analytics',
            desc: 'Ingresos diarios, semanales y mensuales. Servicios más populares, desempeño por profesional y tendencias de tu negocio.',
          },
          {
            icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="19" cy="6" r="3"/><path d="M22 9h-3.5"/></svg>`,
            nombre: 'Gestión de Equipo',
            desc: 'Agenda por profesional, control de comisiones y planilla. Todo lo que necesitas para administrar tu equipo sin dolor de cabeza.',
          },
        ].map(f => (
          <div class="feature-card card-pad-lg" style="background:#fff;padding:44px 36px;position:relative;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;width:3px;height:0;background:#9e8a78;transition:height .4s ease;" class="feature-accent"></div>
            <Fragment set:html={f.icon} />
            <h3 style="font-family:'Prata',serif;font-size:1.25rem;color:#282828;margin:20px 0 10px;">{f.nombre}</h3>
            <p style="font-size:14px;line-height:1.8;color:#777;margin:0;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       DEMO DEL BOOKING
  ══════════════════════════════════════════ -->
  <section id="demo" class="section-pad" style="padding:100px 24px;background:#fcf9f5;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:60px;">
        <span class="section-label">Para tus clientes</span>
        <h2 class="section-title" style="margin:0 auto;">Tus clientes agendan en 3 pasos simples</h2>
        <div class="section-divider center"></div>
        <p style="max-width:500px;margin:0 auto;font-size:15px;line-height:1.9;">
          Sin apps que instalar, sin registros complicados. Solo entran, eligen y confirman.
        </p>
      </div>

      <div class="cards-grid-260" style="margin-bottom:40px;">
        {[
          {
            n: '01',
            titulo: 'Elige el negocio',
            desc: 'El cliente busca tu barbería o salón por nombre. Ve tu información y servicios disponibles.',
          },
          {
            n: '02',
            titulo: 'Selecciona fecha y hora',
            desc: 'Elige el tipo de servicio y el horario disponible en tiempo real. Sin llamadas ni esperas.',
          },
          {
            n: '03',
            titulo: 'Confirma la cita',
            desc: 'Ingresa su nombre y teléfono. La cita queda registrada al instante en tu panel de administración.',
          },
        ].map(step => (
          <div class="card-pad-lg" style="background:#fff;padding:44px 36px;">
            <div style="font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#9e8a78;margin-bottom:20px;">{step.n}</div>
            <h3 style="font-family:'Prata',serif;font-size:1.35rem;color:#282828;margin:0 0 14px;">{step.titulo}</h3>
            <p style="font-size:14px;line-height:1.8;color:#777;margin:0;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center;">
        <a href="/agendar" class="btn-gold" style="text-decoration:none;"><span>Probar el booking ahora →</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       POR QUÉ BOOKSTYLE
  ══════════════════════════════════════════ -->
  <section class="section-pad" style="padding:100px 24px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;" class="about-grid">
      <!-- Imagen -->
      <div class="about-img-wrap" style="position:relative;padding-bottom:40px;">
        <img
          src="https://images.unsplash.com/photo-1599351431202-1e0f0137899a?w=640&auto=format&fit=crop&q=80"
          alt="Barbero trabajando con BookStyle"
          class="about-img"
          style="width:80%;aspect-ratio:3/4;object-fit:cover;box-shadow:0 16px 40px rgba(0,0,0,.18);"
        />
        <div class="about-overlay-box" style="position:absolute;bottom:0;right:0;background:#222227;padding:22px 28px;max-width:220px;">
          <div style="font-family:'Prata',serif;font-size:2rem;color:#9e8a78;line-height:1;">Todo</div>
          <div style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#fff;margin-top:6px;">en un solo sistema</div>
        </div>
      </div>

      <!-- Texto -->
      <div>
        <span class="section-label">¿Por qué BookStyle?</span>
        <h2 class="section-title">Hecho para barberías y salones reales</h2>
        <div class="section-divider"></div>
        <div style="display:flex;flex-direction:column;gap:20px;margin-bottom:40px;">
          {[
            { icon: '✓', titulo: 'Todo en uno', desc: 'Sin necesidad de usar 3 apps diferentes para agenda, caja e inventario.' },
            { icon: '✓', titulo: 'Sin comisiones por cita', desc: 'Precio fijo mensual. Puedes agendar todas las citas que quieras.' },
            { icon: '✓', titulo: 'Soporte en español', desc: 'Para barberías y salones en El Salvador y Latinoamérica.' },
            { icon: '✓', titulo: 'Tus datos, bajo tu control', desc: 'No compartimos tu información con competidores.' },
            { icon: '✓', titulo: 'Setup en menos de 24 horas', desc: 'Te ayudamos a configurar tu cuenta y migrar tu información.' },
          ].map(b => (
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <div style="width:28px;height:28px;background:#9e8a78;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
                <span style="color:#fff;font-weight:700;font-size:14px;">{b.icon}</span>
              </div>
              <div>
                <div style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:700;color:#282828;margin-bottom:3px;">{b.titulo}</div>
                <div style="font-size:14px;color:#777;line-height:1.6;">{b.desc}</div>
              </div>
            </div>
          ))}
        </div>
        <a href="#contacto" class="btn-gold" style="text-decoration:none;"><span>Solicitar Demo</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TESTIMONIALES
  ══════════════════════════════════════════ -->
  <section id="testimoniales" class="section-pad" style="padding:100px 24px;background:#fcf9f5;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:60px;">
        <span class="section-label">Lo que dicen nuestros clientes</span>
        <h2 class="section-title" style="margin:0 auto;">Negocios que confían en BookStyle</h2>
        <div class="section-divider center"></div>
      </div>

      <div class="cards-grid-320" style="background:#e0dbd4;">
        {/* <!-- TODO: reemplazar con testimoniales reales --> */}
        {[
          {
            inicial: 'C',
            nombre: 'Carlos Molina',
            negocio: 'BarberKing',
            ciudad: 'San Salvador',
            texto: 'Desde que usamos BookStyle dejamos de perder citas por llamadas perdidas. Todo lo gestionamos desde el panel y los clientes pueden agendar solos. Un antes y un después.',
          },
          {
            inicial: 'L',
            nombre: 'Lorena Gutiérrez',
            negocio: 'Salón Élite',
            ciudad: 'Santa Ana',
            texto: 'El control de caja y el inventario me ahorran horas cada semana. Antes llevaba todo en papel. Ahora en dos clicks sé cuánto ingresé y qué productos me están faltando.',
          },
          {
            inicial: 'R',
            nombre: 'Roberto Escalante',
            negocio: 'Cortes & Style',
            ciudad: 'San Miguel',
            texto: 'Lo mejor es que mis clientes pueden ver horarios disponibles y agendar sin molestarme. Me llega la notificación y ya está. BookStyle cambió cómo trabajo.',
          },
        ].map((t, i) => (
          <div class="card-pad-lg" style="background:#fff;padding:44px 36px;">
            <div style="font-family:'Prata',serif;font-size:3rem;color:#f0ebe3;line-height:1;margin-bottom:16px;">"</div>
            <p style="font-size:15px;line-height:1.9;color:#555;margin:0 0 28px;">{t.texto}</p>
            <div style="display:flex;align-items:center;gap:14px;">
              <div style={`width:48px;height:48px;border-radius:50%;background:${i%2===0?'#222227':'#9e8a78'};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                <span style="font-family:'Prata',serif;font-size:1.3rem;color:#fff;">{t.inicial}</span>
              </div>
              <div>
                <div style="font-family:'Prata',serif;font-size:1rem;color:#282828;">{t.nombre}</div>
                <div style="font-family:'Work Sans',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9e8a78;">{t.negocio} · {t.ciudad}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PRECIOS
  ══════════════════════════════════════════ -->
  <section id="precios" class="section-pad" style="background:#222227;padding:100px 24px;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,#9e8a78 0,#9e8a78 1px,transparent 0,transparent 50%);background-size:12px 12px;"></div>
    <div style="position:relative;z-index:2;max-width:800px;margin:0 auto;">
      <span class="section-label" style="justify-content:center;display:block;">Planes y precios</span>
      <h2 style="font-family:'Prata',serif;font-size:clamp(2rem,4vw,3rem);color:#fff;margin:0 0 20px;">¿Cuánto cuesta BookStyle?</h2>
      <p style="font-size:15px;color:#999;line-height:1.9;margin:0 0 48px;">
        Planes adaptados al tamaño de tu negocio. Sin contratos largos. Sin letra pequeña.
      </p>

      <div class="price-cards-wrap" style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-bottom:48px;text-align:left;max-width:1040px;margin-left:auto;margin-right:auto;">

        <!-- BÁSICO -->
        <div style="background:#2d2d33;padding:44px 32px;position:relative;">
          <div style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:10px;">Básico</div>
          <div style="display:flex;align-items:flex-end;gap:4px;margin-bottom:4px;">
            <span style="font-family:'Prata',serif;font-size:2.4rem;color:#fff;">$34.99</span>
            <span style="font-size:13px;color:rgba(255,255,255,.45);margin-bottom:8px;">/mes</span>
          </div>
          <div style="font-size:13px;color:rgba(255,255,255,.5);margin-bottom:28px;padding-bottom:24px;border-bottom:1px solid rgba(255,255,255,.08);">Para negocios que arrancan</div>
          <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:32px;">
            {['1 barbería / salón','Hasta 3 profesionales','Agenda online','Control de caja básico','Gestión de clientes','Soporte por WhatsApp'].map(item => (
              <div style="display:flex;align-items:center;gap:10px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8a78" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:13px;color:rgba(255,255,255,.8);">{item}</span>
              </div>
            ))}
          </div>
          <a href="#contacto" class="btn-outline" style="display:block;text-align:center;text-decoration:none;border-color:rgba(255,255,255,.25);color:#fff;font-size:11px;height:44px;line-height:44px;padding:0;">Solicitar demo</a>
        </div>

        <!-- PROFESIONAL -->
        <div style="background:#9e8a78;padding:44px 32px;position:relative;">
          <div style="position:absolute;top:0;left:0;right:0;background:#7d6b5e;text-align:center;padding:7px;font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#fff;">Más popular</div>
          <div style="padding-top:28px;">
            <div style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:10px;">Profesional</div>
            <div style="display:flex;align-items:flex-end;gap:4px;margin-bottom:4px;">
              <span style="font-family:'Prata',serif;font-size:2.4rem;color:#fff;">$69.99</span>
              <span style="font-size:13px;color:rgba(255,255,255,.55);margin-bottom:8px;">/mes</span>
            </div>
            <div style="font-size:13px;color:rgba(255,255,255,.6);margin-bottom:28px;padding-bottom:24px;border-bottom:1px solid rgba(255,255,255,.15);">Para negocios en crecimiento</div>
            <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:32px;">
              {['Hasta 3 barberías / salones','Profesionales ilimitados','Todo lo del plan Básico','Inventario & Compras','Reportes & Analytics','Gestión de equipo'].map(item => (
                <div style="display:flex;align-items:center;gap:10px;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:13px;color:rgba(255,255,255,.9);">{item}</span>
                </div>
              ))}
            </div>
            <a href="#contacto" class="btn-gold" style="display:block;text-align:center;text-decoration:none;background:#fff;color:#222227;font-size:11px;height:44px;line-height:44px;padding:0;"><span>Solicitar demo</span></a>
          </div>
        </div>

        <!-- ENTERPRISE -->
        <div style="background:#1c1c21;padding:44px 32px;position:relative;border-top:2px solid #9e8a78;">
          <div style="position:absolute;top:0;left:0;right:0;background:#9e8a78;text-align:center;padding:7px;font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#fff;">Todo incluido</div>
          <div style="padding-top:28px;">
            <div style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:10px;">Enterprise</div>
