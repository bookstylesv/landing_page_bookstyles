  <section id="contacto" class="section-pad" style="padding:100px 24px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;" class="contact-grid">
      <!-- Info -->
      <div>
        <span class="section-label">Empieza hoy</span>
        <h2 class="section-title">Solicita una demo gratuita</h2>
        <div class="section-divider"></div>
        <p style="font-size:15px;line-height:1.9;margin-bottom:36px;">
